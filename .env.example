# =============================================================================
# FICHIER EXEMPLE DE CONFIGURATION - COPIEZ CE FICHIER EN .env PUIS MODIFIEZ
# =============================================================================
# cp .env.example .env
# =============================================================================

# Symfony
APP_ENV=dev
APP_SECRET=CHANGEZ_MOI_AVEC_UNE_CLE_SECRETE_ALEATOIRE

# =============================================================================
# BASE DE DONNÉES
# =============================================================================
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?serverVersion=VERSION
#
# PRODUCTION (NE PAS UTILISER EN DEV !)
# DATABASE_URL="mysql://user_prod:password_prod@localhost:3306/bdd_books_prod?serverVersion=8.0"
#
# DÉVELOPPEMENT (base de données locale ou clone)
DATABASE_URL="mysql://root:password@127.0.0.1:3306/bdd_books_dev?serverVersion=8.0"

# =============================================================================
# PUPPETEER SERVICE (scraping)
# =============================================================================
PUPPETEER_SERVICE_URL=http://localhost:3000
PUPPETEER_API_KEY=VOTRE_CLE_API_PUPPETEER

# =============================================================================
# MAILER (optionnel)
# =============================================================================
# MAILER_DSN=smtp://localhost:1025

# =============================================================================
# MESSENGER (optionnel)
# =============================================================================
# MESSENGER_TRANSPORT_DSN=doctrine://default

# =============================================================================
# JEUX VIDÉO - IGDB via Twitch (gratuit)
# =============================================================================
# 1. Créez un compte Twitch Developer : https://dev.twitch.tv/console
# 2. Créez une application (catégorie: Website Integration)
# 3. Copiez le Client ID et générez un Client Secret
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# =============================================================================
# TRADUCTION - DeepL API Free (500k caractères/mois gratuits)
# =============================================================================
# Créez un compte sur https://www.deepl.com/pro-api
# Utilisez la clé API Free (se termine par :fx)
DEEPL_API_KEY=

{% extends 'base.html.twig' %}

{% block title %}{{ game.titre }} - BDD-Games{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #6f42c1;"><i class="fas fa-gamepad"></i> {{ game.titre }}</h2>
        <div>
            <a href="{{ path('game_list') }}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
            {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                <a href="{{ path('game_edit', {id: game.id}) }}" class="btn btn-warning">
                    <i class="fas fa-edit"></i> Modifier
                </a>
            {% endif %}
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm">
                <div class="position-relative">
                    {% set mainImage = game.mainImage %}
                    {% if mainImage %}
                        <img src="{{ mainImage }}" class="card-img-top" alt="{{ game.titre }}" style="max-height: 400px; object-fit: contain; background: #f8f9fa; cursor: pointer;" onclick="openLightbox(0)">
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-light" style="height: 300px;">
                            <i class="fas fa-gamepad fa-5x text-muted"></i>
                        </div>
                    {% endif %}
                </div>
                
                {% if game.images|length > 1 %}
                <div class="card-body p-2">
                    <div class="d-flex flex-wrap">
                        {% for image in game.images %}
                        <div class="m-1" style="cursor: pointer;" onclick="openLightbox({{ loop.index0 }})">
                            <img src="{{ image.displayUrl }}" alt="Image {{ loop.index }}" class="rounded border" style="height: 60px; width: 60px; object-fit: cover;">
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header" style="background: linear-gradient(135deg, #6f42c1 0%, #e83e8c 100%);">
                    <h5 class="mb-0 text-white"><i class="fas fa-info-circle"></i> Informations</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong><i class="fas fa-tv"></i> Console:</strong> {{ game.console }}</p>
                            {% if game.annee %}
                            <p><strong><i class="fas fa-calendar"></i> Année:</strong> {{ game.annee }}</p>
                            {% endif %}
                            {% if game.editeur %}
                            <p><strong><i class="fas fa-building"></i> Éditeur:</strong> {{ game.editeur }}</p>
                            {% endif %}
                            {% if game.developpeur %}
                            <p><strong><i class="fas fa-code"></i> Développeur:</strong> {{ game.developpeur }}</p>
                            {% endif %}
                        </div>
                        <div class="col-md-6">
                            {% if game.genre %}
                            <p><strong><i class="fas fa-tags"></i> Genre:</strong> {{ game.genre }}</p>
                            {% endif %}
                            {% if game.classification %}
                            <p><strong><i class="fas fa-shield-alt"></i> Classification:</strong> 
                                <span class="badge badge-secondary">{{ game.classification }}</span>
                            </p>
                            {% endif %}
                        </div>
                    </div>
                    {% if game.description %}
                    <hr>
                    <p class="mb-0">{{ game.description|nl2br }}</p>
                    {% endif %}
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #6f42c1 0%, #e83e8c 100%);">
                    <h5 class="mb-0 text-white"><i class="fas fa-users"></i> Propriétaires ({{ owners|length }})</h5>
                    {% if is_granted('IS_AUTHENTICATED_FULLY') and not userHasGame %}
                        <a href="{{ path('game_add_owner', {id: game.id}) }}" class="btn btn-sm btn-light">
                            <i class="fas fa-plus"></i> Ajouter à ma collection
                        </a>
                    {% endif %}
                </div>
                <div class="card-body p-0">
                    {% if owners|length == 0 %}
                        <div class="p-3 text-center text-muted">
                            <i class="fas fa-info-circle"></i> Aucun propriétaire pour ce jeu.
                        </div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Utilisateur</th>
                                        <th>Édition</th>
                                        <th>Type</th>
                                        <th>Store/Support</th>
                                        <th>Commentaire</th>
                                        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                        <th class="text-center">Actions</th>
                                        {% endif %}
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for lien in owners %}
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                {% if lien.user.avatar %}
                                                    <img src="/uploads/avatars/{{ lien.user.avatar }}" alt="Avatar" class="rounded-circle mr-2" style="width: 30px; height: 30px; object-fit: cover;">
                                                {% else %}
                                                    <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center mr-2" style="width: 30px; height: 30px;">
                                                        <i class="fas fa-user fa-sm"></i>
                                                    </div>
                                                {% endif %}
                                                {{ lien.user.name }} {{ lien.user.lastName }}
                                            </div>
                                        </td>
                                        <td>
                                            {{ lien.nomEdition|default('Standard') }}
                                            {% if lien.displayImage %}
                                                <img src="{{ lien.displayImage }}" alt="Photo" class="ml-2 rounded" style="height: 30px; cursor: pointer;" onclick="window.open('{{ lien.displayImage }}', '_blank')">
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if lien.typeEdition == 'physique' %}
                                                <span class="badge badge-primary"><i class="fas fa-box"></i> Physique</span>
                                            {% else %}
                                                <span class="badge badge-info"><i class="fas fa-cloud"></i> Numérique</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if lien.typeEdition == 'numerique' and lien.store %}
                                                {{ lien.store }}
                                            {% elseif lien.typeEdition == 'physique' %}
                                                <span class="text-muted">-</span>
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                        <td>{{ lien.commentaire|default('-')|u.truncate(50, '...') }}</td>
                                        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                        <td class="text-center">
                                            {% if lien.user == app.user %}
                                                <a href="{{ path('game_edit_owner', {id: game.id, lienId: lien.id}) }}" class="btn btn-sm btn-outline-primary" title="Modifier">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <form action="{{ path('game_remove_owner', {id: game.id, lienId: lien.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Retirer ce jeu de votre collection ?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ lien.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Retirer">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                        </td>
                                        {% endif %}
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Lightbox Modal -->
<div class="modal fade" id="lightboxModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark">
            <div class="modal-header border-0">
                <span class="text-white" id="lightboxCounter"></span>
                <button type="button" class="close text-white" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body text-center p-0">
                <img id="lightboxImage" src="" class="img-fluid" style="max-height: 80vh;">
            </div>
            <div class="modal-footer border-0 justify-content-center">
                <button type="button" class="btn btn-outline-light" onclick="prevImage()">
                    <i class="fas fa-chevron-left"></i> Précédent
                </button>
                <button type="button" class="btn btn-outline-light" onclick="nextImage()">
                    Suivant <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
var images = [
    {% if game.coverUrl %}'{{ game.coverUrl }}',{% endif %}
    {% for image in game.images %}'{{ image.displayUrl }}'{% if not loop.last %},{% endif %}{% endfor %}
];
var currentIndex = 0;

function openLightbox(index) {
    currentIndex = index;
    updateLightbox();
    $('#lightboxModal').modal('show');
}

function updateLightbox() {
    if (images.length > 0) {
        $('#lightboxImage').attr('src', images[currentIndex]);
        $('#lightboxCounter').text((currentIndex + 1) + ' / ' + images.length);
    }
}

function prevImage() {
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    updateLightbox();
}

function nextImage() {
    currentIndex = (currentIndex + 1) % images.length;
    updateLightbox();
}

$(document).keydown(function(e) {
    if ($('#lightboxModal').hasClass('show')) {
        if (e.keyCode == 37) prevImage();
        if (e.keyCode == 39) nextImage();
        if (e.keyCode == 27) $('#lightboxModal').modal('hide');
    }
});
</script>
{% endblock %}

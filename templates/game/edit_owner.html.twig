{% extends 'base.html.twig' %}

{% block title %}Modifier ma collection - {{ game.titre }}{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #6f42c1 0%, #e83e8c 100%);">
                    <h5 class="mb-0 text-white">
                        <i class="fas fa-edit"></i> Modifier ma collection
                    </h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        {% if game.mainImage %}
                            <img src="{{ game.mainImage }}" alt="{{ game.titre }}" class="rounded shadow" style="max-height: 150px;">
                        {% endif %}
                        <h4 class="mt-3">{{ game.titre }}</h4>
                        <p class="text-muted">{% if game.annee %}({{ game.annee }}){% endif %}</p>
                    </div>

                    <form method="post" enctype="multipart/form-data">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><strong>Console / Plateforme</strong></label>
                                    <select name="console" class="form-control" required>
                                        {% set consoles_list = {
                                            'PS5': 'PlayStation 5', 'PS4': 'PlayStation 4', 'PS3': 'PlayStation 3',
                                            'PS2': 'PlayStation 2', 'PS1': 'PlayStation', 'PSVita': 'PS Vita',
                                            'PSP': 'PSP', 'XSX': 'Xbox Series X', 'XOne': 'Xbox One',
                                            'X360': 'Xbox 360', 'Xbox': 'Xbox', 'Switch': 'Nintendo Switch',
                                            'WiiU': 'Wii U', 'Wii': 'Wii', 'GameCube': 'GameCube',
                                            'N64': 'Nintendo 64', '3DS': 'Nintendo 3DS', 'DS': 'Nintendo DS',
                                            'GBA': 'Game Boy Advance', 'GB': 'Game Boy', 'PC': 'PC',
                                            'Mac': 'Mac', 'Linux': 'Linux', 'Android': 'Android', 'iOS': 'iOS'
                                        } %}
                                        {% for code, label in consoles_list %}
                                            <option value="{{ code }}" {% if lien.console == code %}selected{% endif %}>{{ label }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><strong>Type d'édition</strong></label>
                                    <select name="type_edition" id="typeEdition" class="form-control">
                                        <option value="physique" {% if lien.typeEdition == 'physique' %}selected{% endif %}>Physique</option>
                                        <option value="numerique" {% if lien.typeEdition == 'numerique' %}selected{% endif %}>Numérique</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><strong>Nom de l'édition</strong></label>
                                    <input type="text" name="nom_edition" class="form-control" value="{{ lien.nomEdition }}" placeholder="Standard, Collector, GOTY...">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><strong>Date d'achat</strong></label>
                                    <input type="date" name="date_achat" class="form-control" value="{{ lien.dateAchat ? lien.dateAchat|date('Y-m-d') : '' }}">
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><strong>Prix d'achat (€)</strong></label>
                                    <input type="number" step="0.01" name="prix_achat" class="form-control" value="{{ lien.prixAchat }}" placeholder="0.00">
                                </div>
                            </div>
                        </div>

                        <div class="form-group" id="storeField" {% if lien.typeEdition != 'numerique' %}style="display: none;"{% endif %}>
                            <label><strong>Store</strong></label>
                            <select name="store" class="form-control">
                                <option value="">-- Sélectionner --</option>
                                {% set stores = ['Steam', 'Epic Games', 'GOG', 'PlayStation Store', 'Xbox Store', 'Nintendo eShop', 'Ubisoft Connect', 'EA App', 'Battle.net', 'Autre'] %}
                                {% for store in stores %}
                                    <option value="{{ store }}" {% if lien.store == store %}selected{% endif %}>{{ store }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="form-group" id="imageField">
                            <label><strong><i class="fas fa-camera"></i> Photo de votre édition</strong> <small class="text-muted">(optionnel)</small></label>
                            {% if lien.displayImage %}
                                <div class="mb-2 text-center">
                                    <img src="{{ lien.displayImage }}" alt="Photo actuelle" class="img-thumbnail" style="max-height: 120px;">
                                    <small class="d-block text-muted"><i class="fas fa-image"></i> Image actuelle</small>
                                </div>
                            {% endif %}
                            <div class="btn-group btn-group-sm mb-2 d-block" role="group">
                                <button type="button" class="btn btn-outline-secondary active" id="btnUploadFile">
                                    <i class="fas fa-upload"></i> Fichier
                                </button>
                                <button type="button" class="btn btn-outline-secondary" id="btnUploadUrl">
                                    <i class="fas fa-link"></i> URL
                                </button>
                            </div>
                            <div id="fileUploadSection">
                                <div class="custom-file mb-2">
                                    <input type="file" name="image_perso" class="custom-file-input" id="imagePersoInput" accept="image/*">
                                    <label class="custom-file-label" for="imagePersoInput" data-browse="Parcourir">{% if lien.displayImage %}Changer l'image...{% else %}Choisir une image...{% endif %}</label>
                                </div>
                            </div>
                            <div id="urlUploadSection" style="display: none;">
                                <input type="url" name="image_perso_url" class="form-control mb-2" id="imagePersoUrl" placeholder="https://exemple.com/image.jpg">
                            </div>
                            <small class="text-muted">{% if lien.displayImage %}Laissez vide pour conserver l'image actuelle{% else %}Ajoutez une photo de votre boîte, steelbook, etc.{% endif %}</small>
                            <div id="imagePreview" class="mt-2 text-center" style="display: none;">
                                <img id="previewImg" src="" class="img-thumbnail" style="max-height: 150px;">
                                <br><small class="text-success"><i class="fas fa-check"></i> Nouvelle image sélectionnée</small>
                            </div>
                        </div>

                        <div class="form-group">
                            <label><strong>Commentaire</strong></label>
                            <textarea name="commentaire" class="form-control" rows="2" placeholder="Notes personnelles...">{{ lien.commentaire }}</textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ path('game_detail', {id: game.id}) }}" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Annuler
                            </a>
                            <button type="submit" class="btn" style="background: linear-gradient(135deg, #6f42c1 0%, #e83e8c 100%); color: white;">
                                <i class="fas fa-save"></i> Enregistrer
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
$(document).ready(function() {
    $('#typeEdition').change(function() {
        if ($(this).val() === 'numerique') {
            $('#storeField').show();
        } else {
            $('#storeField').hide();
        }
    });
    
    // Toggle fichier / URL
    $('#btnUploadFile').click(function() {
        $(this).addClass('active');
        $('#btnUploadUrl').removeClass('active');
        $('#fileUploadSection').show();
        $('#urlUploadSection').hide();
        $('#imagePersoUrl').val('');
        $('#imagePreview').hide();
    });
    
    $('#btnUploadUrl').click(function() {
        $(this).addClass('active');
        $('#btnUploadFile').removeClass('active');
        $('#urlUploadSection').show();
        $('#fileUploadSection').hide();
        $('#imagePersoInput').val('');
        $('.custom-file-label').text('Choisir une image...');
        $('#imagePreview').hide();
    });
    
    // Prévisualisation fichier
    $('#imagePersoInput').change(function(e) {
        var file = e.target.files[0];
        if (file) {
            $(this).next('.custom-file-label').text(file.name);
            if (file.type.match('image.*')) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    $('#previewImg').attr('src', e.target.result);
                    $('#imagePreview').show();
                };
                reader.readAsDataURL(file);
            }
        } else {
            $(this).next('.custom-file-label').text('Choisir une image...');
            $('#imagePreview').hide();
        }
    });
    
    // Prévisualisation URL
    $('#imagePersoUrl').on('input', function() {
        var url = $(this).val().trim();
        if (url) {
            $('#previewImg').attr('src', url).on('load', function() {
                $('#imagePreview').show();
            }).on('error', function() {
                $('#imagePreview').hide();
            });
        } else {
            $('#imagePreview').hide();
        }
    });
});
</script>
{% endblock %}

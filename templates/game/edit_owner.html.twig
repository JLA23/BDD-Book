{% extends 'base.html.twig' %}

{% block title %}Modifier ma collection - {{ game.titre }}{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #6f42c1 0%, #e83e8c 100%);">
                    <h5 class="mb-0 text-white">
                        <i class="fas fa-edit"></i> Modifier ma collection
                    </h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        {% if game.mainImage %}
                            <img src="{{ game.mainImage }}" alt="{{ game.titre }}" class="rounded shadow" style="max-height: 150px;">
                        {% endif %}
                        <h4 class="mt-3">{{ game.titre }}</h4>
                        <p class="text-muted">{{ game.console }} {% if game.annee %}({{ game.annee }}){% endif %}</p>
                    </div>

                    <form method="post" enctype="multipart/form-data">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><strong>Type d'édition</strong></label>
                                    <select name="type_edition" id="typeEdition" class="form-control">
                                        <option value="physique" {% if lien.typeEdition == 'physique' %}selected{% endif %}>Physique</option>
                                        <option value="numerique" {% if lien.typeEdition == 'numerique' %}selected{% endif %}>Numérique</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><strong>Nom de l'édition</strong></label>
                                    <input type="text" name="nom_edition" class="form-control" value="{{ lien.nomEdition }}" placeholder="Standard, Collector, GOTY...">
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><strong>Date d'achat</strong></label>
                                    <input type="date" name="date_achat" class="form-control" value="{{ lien.dateAchat ? lien.dateAchat|date('Y-m-d') : '' }}">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><strong>Prix d'achat (€)</strong></label>
                                    <input type="number" step="0.01" name="prix_achat" class="form-control" value="{{ lien.prixAchat }}" placeholder="0.00">
                                </div>
                            </div>
                        </div>

                        <div class="form-group" id="storeField" {% if lien.typeEdition != 'numerique' %}style="display: none;"{% endif %}>
                            <label><strong>Store</strong></label>
                            <select name="store" class="form-control">
                                <option value="">-- Sélectionner --</option>
                                {% set stores = ['Steam', 'Epic Games', 'GOG', 'PlayStation Store', 'Xbox Store', 'Nintendo eShop', 'Ubisoft Connect', 'EA App', 'Battle.net', 'Autre'] %}
                                {% for store in stores %}
                                    <option value="{{ store }}" {% if lien.store == store %}selected{% endif %}>{{ store }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="form-group" id="imageField">
                            <label><strong>Photo de votre édition</strong> <small class="text-muted">(optionnel)</small></label>
                            {% if lien.displayImage %}
                                <div class="mb-2">
                                    <img src="{{ lien.displayImage }}" alt="Photo actuelle" class="rounded border" style="max-height: 100px;">
                                    <small class="d-block text-muted">Image actuelle</small>
                                </div>
                            {% endif %}
                            <input type="file" name="image_perso" class="form-control-file" accept="image/*">
                            <small class="text-muted">Laissez vide pour conserver l'image actuelle</small>
                        </div>

                        <div class="form-group">
                            <label><strong>Commentaire</strong></label>
                            <textarea name="commentaire" class="form-control" rows="2" placeholder="Notes personnelles...">{{ lien.commentaire }}</textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ path('game_detail', {id: game.id}) }}" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Annuler
                            </a>
                            <button type="submit" class="btn" style="background: linear-gradient(135deg, #6f42c1 0%, #e83e8c 100%); color: white;">
                                <i class="fas fa-save"></i> Enregistrer
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
$(document).ready(function() {
    $('#typeEdition').change(function() {
        if ($(this).val() === 'numerique') {
            $('#storeField').show();
        } else {
            $('#storeField').hide();
        }
    });
});
</script>
{% endblock %}

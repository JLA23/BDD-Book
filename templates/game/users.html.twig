{% extends 'base.html.twig' %}

{% block title %}Collections - BDD-Games{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #6f42c1;"><i class="fas fa-users"></i> Collections par utilisateur</h2>
        <a href="{{ path('game_index') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </div>

    {% if users|length == 0 %}
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Aucun utilisateur n'a encore de jeux dans sa collection.
        </div>
    {% else %}
        <div class="row">
            {% for user in users %}
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card h-100 shadow-sm hover-card">
                    <div class="card-body text-center">
                        {% if user.avatar %}
                            <img src="/uploads/avatars/{{ user.avatar }}" alt="Avatar" class="rounded-circle mb-3" style="width: 80px; height: 80px; object-fit: cover;">
                        {% else %}
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;">
                                <i class="fas fa-user fa-2x"></i>
                            </div>
                        {% endif %}
                        <h5 class="card-title">{{ user.name }} {{ user.lastName }}</h5>
                        <p class="card-text">
                            <span class="badge badge-pill px-3 py-2" style="background-color: #6f42c1; color: white;">
                                <i class="fas fa-gamepad"></i> {{ user.gamesCount }} jeu(x)
                            </span>
                        </p>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<style>
    .hover-card { transition: transform 0.2s, box-shadow 0.2s; }
    .hover-card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important; }
</style>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Ajouter un jeu{% endblock %}

{% block body %}
<div class="container mt-4">

    <h1 class="mb-4"><i class="fas fa-plus-circle mr-2" style="color: #6f42c1;"></i>Ajouter un jeu</h1>

    <div class="row justify-content-center">
        <!-- Mode 1 : Recherche via API -->
        <div class="col-md-5 mb-4">
            <div class="card h-100 shadow-sm" style="border-color: #6f42c1;">
                <div class="card-body text-center d-flex flex-column">
                    <div class="mb-3">
                        <i class="fas fa-search fa-3x" style="color: #6f42c1;"></i>
                    </div>
                    <h5 class="card-title">Rechercher via API</h5>
                    <p class="card-text text-muted flex-grow-1">
                        Rechercher un jeu par son <strong>titre</strong> via l'API IGDB.
                        Les informations seront récupérées automatiquement (titre, éditeur, date de sortie, images...).
                    </p>
                    {% if apiConfigured %}
                        <div class="mb-3">
                            <span class="badge badge-light border">
                                <i class="fas fa-gamepad mr-1"></i>IGDB
                            </span>
                        </div>
                    {% else %}
                        <div class="mb-3">
                            <span class="badge badge-warning">
                                <i class="fas fa-exclamation-triangle mr-1"></i>API non configurée
                            </span>
                        </div>
                    {% endif %}
                    <a href="{{ path('game_search_api') }}" class="btn btn-block mt-auto text-white" style="background: linear-gradient(135deg, #6f42c1 0%, #e83e8c 100%);">
                        <i class="fas fa-search mr-1"></i> Rechercher via API
                    </a>
                </div>
            </div>
        </div>

        <!-- Mode 2 : Saisie manuelle -->
        <div class="col-md-5 mb-4">
            <div class="card h-100 shadow-sm border-warning">
                <div class="card-body text-center d-flex flex-column">
                    <div class="mb-3">
                        <i class="fas fa-edit fa-3x text-warning"></i>
                    </div>
                    <h5 class="card-title">Saisie manuelle</h5>
                    <p class="card-text text-muted flex-grow-1">
                        Remplir manuellement toutes les informations du jeu.
                        Idéal pour les jeux rares, anciens ou non référencés dans les bases de données.
                    </p>
                    <a href="{{ path('game_new') }}" class="btn btn-warning btn-block mt-auto">
                        <i class="fas fa-edit mr-1"></i> Saisie manuelle
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

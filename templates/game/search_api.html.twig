{% extends 'base.html.twig' %}

{% block title %}Recherche API - BDD-Games{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 style="color: #6f42c1;"><i class="fas fa-search"></i> Recherche via API</h2>
                <a href="{{ path('game_index') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>

            {% if not apiConfigured %}
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle"></i> <strong>API non configurée</strong>
                <p class="mb-0">Configurez vos identifiants Twitch dans le fichier <code>.env</code> :</p>
                <code>TWITCH_CLIENT_ID=votre_client_id</code><br>
                <code>TWITCH_CLIENT_SECRET=votre_client_secret</code>
                <p class="mb-0 mt-2">Créez une application sur <a href="https://dev.twitch.tv/console" target="_blank">dev.twitch.tv/console</a></p>
            </div>
            {% else %}
            <div class="card shadow-sm mb-4">
                <div class="card-header" style="background: linear-gradient(135deg, #6f42c1 0%, #e83e8c 100%);">
                    <h5 class="mb-0 text-white"><i class="fas fa-gamepad"></i> Rechercher un jeu</h5>
                </div>
                <div class="card-body">
                    <div class="input-group">
                        <input type="text" id="searchQuery" class="form-control form-control-lg" placeholder="Titre du jeu (ex: Zelda, God of War, Elden Ring...)">
                        <div class="input-group-append">
                            <button class="btn btn-lg" id="searchBtn" style="background: linear-gradient(135deg, #6f42c1 0%, #e83e8c 100%); color: white;">
                                <i class="fas fa-search"></i> Rechercher
                            </button>
                        </div>
                    </div>
                    <small class="text-muted">Recherche via l'API IGDB (Twitch)</small>
                </div>
            </div>

            <div id="loadingSpinner" class="text-center py-5" style="display: none;">
                <div class="spinner-border text-purple" role="status">
                    <span class="sr-only">Chargement...</span>
                </div>
                <p class="mt-2 text-muted">Recherche en cours...</p>
            </div>

            <div id="searchResults"></div>

            <div id="gameDetails" style="display: none;">
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #6f42c1 0%, #e83e8c 100%);">
                        <h5 class="mb-0 text-white"><i class="fas fa-info-circle"></i> Détails du jeu</h5>
                        <button class="btn btn-sm btn-light" onclick="$('#gameDetails').hide(); $('#searchResults').show();">
                            <i class="fas fa-arrow-left"></i> Retour aux résultats
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 text-center">
                                <img id="detailCover" src="" class="img-fluid rounded shadow mb-3" style="max-height: 300px;">
                            </div>
                            <div class="col-md-8">
                                <h3 id="detailTitle"></h3>
                                <p><strong>Année:</strong> <span id="detailYear"></span></p>
                                <p><strong>Éditeur:</strong> <span id="detailPublisher"></span></p>
                                <p><strong>Développeur:</strong> <span id="detailDeveloper"></span></p>
                                <p><strong>Genre:</strong> <span id="detailGenre"></span></p>
                                <p><strong>Classification:</strong> <span id="detailRating"></span></p>
                                <p><strong>Plateformes:</strong> <span id="detailPlatforms"></span></p>
                                
                                <div id="detailDescription" class="mt-3" style="max-height: 150px; overflow-y: auto;"></div>
                            </div>
                        </div>
                        
                        <hr>
                        <h5>Sélectionner la plateforme</h5>
                        <div id="platformSelect" class="mb-3"></div>
                        
                        <div class="text-center">
                            <button class="btn btn-lg btn-success" id="addGameBtn">
                                <i class="fas fa-plus"></i> Ajouter ce jeu
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
var currentGame = null;
var selectedPlatform = null;

$('#searchQuery').keypress(function(e) {
    if (e.which == 13) $('#searchBtn').click();
});

$('#searchBtn').click(function() {
    var query = $('#searchQuery').val().trim();
    if (!query) { alert('Veuillez saisir un titre'); return; }
    
    $('#loadingSpinner').show();
    $('#searchResults').hide();
    $('#gameDetails').hide();
    
    $.ajax({
        url: '{{ path("game_api_search") }}',
        data: { q: query },
        success: function(response) {
            $('#loadingSpinner').hide();
            
            if (response.results && response.results.length > 0) {
                var html = '<div class="row">';
                response.results.forEach(function(game) {
                    html += '<div class="col-md-4 col-lg-3 mb-4">';
                    html += '<div class="card h-100 shadow-sm hover-card" style="cursor: pointer;" onclick="loadGameDetails(' + game.id + ')">';
                    if (game.cover) {
                        html += '<img src="' + game.cover + '" class="card-img-top" style="height: 180px; object-fit: cover;">';
                    } else {
                        html += '<div class="d-flex align-items-center justify-content-center bg-light" style="height: 180px;"><i class="fas fa-gamepad fa-3x text-muted"></i></div>';
                    }
                    html += '<div class="card-body p-2">';
                    html += '<h6 class="card-title mb-1 text-truncate">' + game.titre + '</h6>';
                    html += '<p class="card-text small text-muted mb-0">';
                    if (game.annee) html += game.annee;
                    if (game.genres) html += ' • ' + game.genres.split(',')[0];
                    html += '</p>';
                    if (game.platforms && game.platforms.length > 0) {
                        html += '<p class="card-text small text-muted mb-0">' + game.platforms.slice(0, 3).join(', ') + '</p>';
                    }
                    html += '</div></div></div>';
                });
                html += '</div>';
                $('#searchResults').html(html).show();
            } else {
                $('#searchResults').html('<div class="alert alert-info"><i class="fas fa-info-circle"></i> Aucun résultat trouvé.</div>').show();
            }
        },
        error: function() {
            $('#loadingSpinner').hide();
            $('#searchResults').html('<div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> Erreur lors de la recherche.</div>').show();
        }
    });
});

function loadGameDetails(gameId) {
    $('#loadingSpinner').show();
    $('#searchResults').hide();
    
    $.ajax({
        url: '{{ path("game_api_details", {gameId: 0}) }}'.replace('/0', '/' + gameId),
        xhrFields: { withCredentials: true },
        success: function(response) {
            $('#loadingSpinner').hide();
            
            if (response.game) {
                currentGame = response.game;
                
                $('#detailTitle').text(currentGame.titre);
                $('#detailYear').text(currentGame.annee || 'N/A');
                $('#detailPublisher').text(currentGame.editeur || 'N/A');
                $('#detailDeveloper').text(currentGame.developpeur || 'N/A');
                $('#detailGenre').text(currentGame.genre || 'N/A');
                $('#detailRating').text(currentGame.classification || 'N/A');
                $('#detailDescription').html(currentGame.description ? currentGame.description.substring(0, 500) + '...' : '');
                
                if (currentGame.cover) {
                    $('#detailCover').attr('src', currentGame.cover).show();
                } else {
                    $('#detailCover').hide();
                }
                
                // Plateformes
                var platformsHtml = '';
                if (currentGame.platforms && currentGame.platforms.length > 0) {
                    $('#detailPlatforms').text(currentGame.platforms.map(p => p.name).join(', '));
                    
                    currentGame.platforms.forEach(function(p, i) {
                        var checked = i === 0 ? 'checked' : '';
                        platformsHtml += '<div class="custom-control custom-radio custom-control-inline">';
                        platformsHtml += '<input type="radio" id="platform' + i + '" name="platform" class="custom-control-input" value="' + p.slug + '" ' + checked + '>';
                        platformsHtml += '<label class="custom-control-label" for="platform' + i + '">' + p.name + '</label>';
                        platformsHtml += '</div>';
                    });
                }
                $('#platformSelect').html(platformsHtml);
                
                $('#gameDetails').show();
            }
        },
        error: function(xhr, status, error) {
            $('#loadingSpinner').hide();
            var errorMsg = 'Erreur lors du chargement des détails';
            try {
                var response = JSON.parse(xhr.responseText);
                if (response.error) errorMsg = response.error;
            } catch(e) {
                errorMsg += ': ' + error + ' (Status: ' + xhr.status + ')';
            }
            alert(errorMsg);
            $('#searchResults').show();
        }
    });
}

$('#addGameBtn').click(function() {
    if (!currentGame) return;
    
    var platformSlug = $('input[name="platform"]:checked').val();
    var platformName = $('input[name="platform"]:checked').next('label').text();
    
    // Convertir le slug en code console
    var consoleCode = platformToConsole(platformSlug);
    
    var params = new URLSearchParams({
        prefill: '1',
        titre: currentGame.titre,
        console: consoleCode,
        annee: currentGame.annee || '',
        editeur: currentGame.editeur || '',
        developpeur: currentGame.developpeur || '',
        genre: currentGame.genre || '',
        classification: currentGame.classification || '',
        description: (currentGame.description || '').substring(0, 1000),
        cover: currentGame.cover || '',
        externalId: currentGame.id
    });
    
    window.location.href = '{{ path("game_new") }}?' + params.toString();
});

function platformToConsole(slug) {
    var mapping = {
        'playstation5': 'PS5',
        'playstation4': 'PS4',
        'playstation3': 'PS3',
        'playstation2': 'PS2',
        'playstation1': 'PS1',
        'ps-vita': 'PSVita',
        'psp': 'PSP',
        'xbox-series-x': 'XSX',
        'xbox-one': 'XOne',
        'xbox360': 'X360',
        'xbox-old': 'Xbox',
        'nintendo-switch': 'Switch',
        'wii-u': 'WiiU',
        'wii': 'Wii',
        'gamecube': 'GameCube',
        'nintendo-64': 'N64',
        'nintendo-3ds': '3DS',
        'nintendo-ds': 'DS',
        'game-boy-advance': 'GBA',
        'game-boy': 'GB',
        'pc': 'PC',
        'macos': 'Mac',
        'linux': 'Linux',
        'android': 'Android',
        'ios': 'iOS'
    };
    return mapping[slug] || 'Autre';
}
</script>

<style>
.hover-card { transition: transform 0.2s, box-shadow 0.2s; }
.hover-card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important; }
.text-purple { color: #6f42c1; }
</style>
{% endblock %}

{# index: index du numéro dans le formulaire (0, 1, 2...) #}
{% if app.user %}
    {% set uid = app.user.id %}
    <hr class="ma-propriete-separator">
    <div class="ma-propriete-block">
        <h6 class="font-weight-bold mb-3"><i class="fas fa-user"></i> Ma propriété</h6>
        <div class="card bg-light mb-0">
            <div class="card-body">
                <h6 class="text-muted mb-3"><i class="fas fa-shopping-bag"></i> Informations d'achat</h6>
                <input type="hidden" name="numeros[{{ index }}][users][]" value="{{ uid }}">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-md-0">
                            <label><strong>Date d'achat</strong></label>
                            <input type="date" class="form-control ma-date-achat"
                                   name="numeros[{{ index }}][dates_achat][{{ uid }}]"
                                   value="{{ 'now'|date('Y-m-d') }}">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-0">
                            <label><strong>Prix d'achat</strong> <i class="fas fa-euro-sign"></i></label>
                            <input type="number" step="0.01" min="0" class="form-control"
                                   name="numeros[{{ index }}][prix_achat][{{ uid }}]"
                                   placeholder="0.00">
                        </div>
                    </div>
                </div>
                <div class="form-group mb-0 mt-3">
                    <label><strong>Commentaire</strong></label>
                    <textarea name="numeros[{{ index }}][commentaires][{{ uid }}]" class="form-control" rows="2"
                              placeholder="État du numéro, notes personnelles..."></textarea>
                </div>
            </div>
        </div>
        <p class="small text-muted mt-2 mb-0">
            <i class="fas fa-info-circle"></i> D'autres propriétaires pourront être ajoutés depuis la fiche du numéro.
        </p>
    </div>
{% endif %}

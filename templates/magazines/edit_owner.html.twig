{% extends 'base.html.twig' %}

{% block title %}Modifier ma propriété - {{ magazine.nom }} N°{{ numero.num }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('magazines_list') }}">Magazines</a></li>
            <li class="breadcrumb-item"><a href="{{ path('magazine_detail', {id: magazine.id}) }}">{{ magazine.nom }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('numero_detail', {id: numero.id}) }}">N°{{ numero.num }}</a></li>
            <li class="breadcrumb-item active">Modifier</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header text-white" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                    <h5 class="mb-0"><i class="fas fa-edit"></i> Modifier ma propriété</h5>
                </div>
                <div class="card-body">
                    <p class="lead mb-4">{{ magazine.nom }} — Numéro {{ numero.num }}</p>

                    <form method="post">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><strong>Date d'achat</strong></label>
                                    <input type="date" name="date_achat" class="form-control"
                                           value="{{ lien.dateAchat ? lien.dateAchat|date('Y-m-d') : '' }}">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><strong>Prix d'achat</strong> <i class="fas fa-euro-sign"></i></label>
                                    <input type="number" step="0.01" min="0" name="prix_achat" class="form-control"
                                           value="{{ lien.prixAchat }}" placeholder="0.00">
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label><strong>Commentaire</strong></label>
                            <textarea name="commentaire" class="form-control" rows="3"
                                      placeholder="État du numéro, notes personnelles...">{{ lien.commentaire }}</textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ path('numero_detail', {id: numero.id}) }}" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save"></i> Enregistrer
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

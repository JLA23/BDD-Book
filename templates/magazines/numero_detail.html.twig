{% extends 'base.html.twig' %}

{% block title %}{{ magazine.nom }} - N°{{ numero.num }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('magazines_list') }}">Magazines</a></li>
            <li class="breadcrumb-item"><a href="{{ path('magazine_detail', {id: magazine.id}) }}">{{ magazine.nom }}</a></li>
            <li class="breadcrumb-item active">N°{{ numero.num }}</li>
        </ol>
    </nav>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="row">
        <div class="col-md-4">
            {% if couvertureImage %}
                <img src="{{ couvertureImage }}" 
                     class="img-fluid rounded shadow" 
                     alt="Couverture N°{{ numero.num }}">
            {% else %}
                <div class="bg-secondary d-flex align-items-center justify-content-center rounded" 
                     style="height: 400px;">
                    <div class="text-center text-white">
                        <i class="fas fa-image fa-4x mb-3"></i>
                        <p>Pas de couverture</p>
                    </div>
                </div>
            {% endif %}
        </div>
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h1>{{ magazine.nom }}</h1>
                    <h2 class="text-muted">Numéro {{ numero.num }}</h2>
                </div>
                {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                    <div>
                        <a href="{{ path('numero_edit', {id: numero.id}) }}" class="btn btn-outline-secondary">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                    </div>
                {% endif %}
            </div>

            <hr>

            <div class="row">
                <div class="col-md-6">
                    <dl>
                        {% if numero.dateParution %}
                            <dt>Date de parution</dt>
                            <dd>{{ numero.dateParution|date('F Y') }}</dd>
                        {% endif %}
                        
                        {% if numero.prix %}
                            <dt>Prix</dt>
                            <dd>
                                {{ numero.prix|number_format(2, ',', ' ') }}
                                {% if numero.monnaie %}
                                    {{ numero.monnaie.symbole }} ({{ numero.monnaie.libelle }})
                                {% else %}
                                    €
                                {% endif %}
                            </dd>
                        {% endif %}
                        
                        {% if numero.EAN %}
                            <dt>Code EAN</dt>
                            <dd>{{ numero.EAN }}</dd>
                        {% endif %}
                    </dl>
                </div>
            </div>

            {% if numero.description %}
                <div class="mt-3">
                    <h5>Résumé</h5>
                    <p>{{ numero.description|nl2br }}</p>
                </div>
            {% endif %}

        </div>
    </div>

    {% embed 'components/proprietaires_card.html.twig' with {
        count: proprietaires|length,
        title: 'Propriétaires de ce numéro',
        body_class: 'p-0'
    } %}
        {% block header_actions %}
            {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                <a href="{{ path('numero_add_owner', {id: numero.id}) }}" class="btn btn-sm btn-success" onclick="event.stopPropagation();">
                    <i class="fas fa-user-plus mr-1"></i> Ajouter un propriétaire
                </a>
            {% endif %}
        {% endblock %}
        {% block content %}
            {% if proprietaires|length == 0 %}
                <div class="p-3 text-center text-muted">
                    <i class="fas fa-info-circle"></i> Aucun propriétaire enregistré pour ce numéro.
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th><i class="fas fa-user"></i> Utilisateur</th>
                                <th><i class="fas fa-calendar"></i> Date d'achat</th>
                                <th><i class="fas fa-euro-sign"></i> Prix</th>
                                <th><i class="fas fa-comment"></i> Commentaire</th>
                                {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                    <th class="text-right"><i class="fas fa-cogs"></i> Actions</th>
                                {% endif %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for lien in proprietaires %}
                            <tr>
                                <td>
                                    <strong>{{ lien.user.name }} {{ lien.user.lastname }}</strong>
                                    <br><small class="text-muted">{{ lien.user.username }}</small>
                                </td>
                                <td>{{ lien.dateAchat ? lien.dateAchat|date('d/m/Y') : '-' }}</td>
                                <td>{% include 'components/owner_prix_cell.html.twig' with { prix: lien.prixAchat } %}</td>
                                <td>{{ lien.commentaire ? lien.commentaire|u.truncate(50, '...') : '-' }}</td>
                                {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                    <td class="text-right text-nowrap">
                                        {% if lien.user == app.user %}
                                            <a href="{{ path('numero_edit_owner', {id: lien.id}) }}" class="btn btn-sm btn-outline-primary" title="Modifier">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        {% endif %}
                                    </td>
                                {% endif %}
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}

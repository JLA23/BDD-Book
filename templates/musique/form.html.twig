{% extends 'base.html.twig' %}

{% block title %}{% if isEdit %}Modifier{% else %}Nouvel{% endif %} album - BDD-Musique{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            {% if duplicateWarning %}
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-triangle"></i> <strong>{{ duplicateWarning.message }}</strong>
                <p class="mb-0 mt-2">
                    <a href="{{ path('musique_detail', {id: duplicateWarning.musique.id}) }}" class="alert-link">
                        Voir l'existant: {{ duplicateWarning.musique.artiste }} - {{ duplicateWarning.musique.titre }}
                    </a>
                </p>
            </div>
            {% endif %}

            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);">
                    <h5 class="mb-0 text-white">
                        <i class="fas fa-{% if isEdit %}edit{% else %}plus{% endif %}"></i>
                        {% if isEdit %}Modifier{% else %}Nouvel{% endif %} album
                    </h5>
                </div>
                <div class="card-body">
                    {% if prefillImages is defined and prefillImages|length > 0 %}
                    <div class="alert alert-info mb-4">
                        <strong><i class="fas fa-info-circle"></i> Import depuis API</strong>
                        <p class="mb-2 small">La pochette sera automatiquement ajoutée.</p>
                        <div class="d-flex flex-wrap">
                            <img src="{{ prefillImages[0].url }}" alt="Pochette" class="mr-2 mb-2 rounded border" style="height: 100px; object-fit: contain;">
                        </div>
                    </div>
                    {% endif %}

                    <form method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                        {{ form_widget(form._token) }}
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="{{ form.artiste.vars.id }}"><strong>Artiste</strong></label>
                                    <input type="text" name="{{ form.artiste.vars.full_name }}" id="{{ form.artiste.vars.id }}" 
                                           class="form-control" value="{{ form.artiste.vars.value }}" 
                                           placeholder="Nom de l'artiste ou groupe">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="{{ form.titre.vars.id }}"><strong>Titre de l'album</strong></label>
                                    <input type="text" name="{{ form.titre.vars.full_name }}" id="{{ form.titre.vars.id }}" 
                                           class="form-control" value="{{ form.titre.vars.value }}" 
                                           placeholder="Titre de l'album" required>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label for="{{ form.type.vars.id }}"><strong>Type</strong></label>
                                    <select name="{{ form.type.vars.full_name }}" id="{{ form.type.vars.id }}" class="form-control">
                                        <option value="">-- Sélectionner --</option>
                                        <option value="album" {% if form.type.vars.value == 'album' %}selected{% endif %}>Album</option>
                                        <option value="single" {% if form.type.vars.value == 'single' %}selected{% endif %}>Single</option>
                                        <option value="ep" {% if form.type.vars.value == 'ep' %}selected{% endif %}>EP</option>
                                        <option value="compilation" {% if form.type.vars.value == 'compilation' %}selected{% endif %}>Compilation</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label for="{{ form.format.vars.id }}"><strong>Format</strong></label>
                                    <select name="{{ form.format.vars.full_name }}" id="{{ form.format.vars.id }}" class="form-control">
                                        <option value="">-- Sélectionner --</option>
                                        <option value="cd" {% if form.format.vars.value == 'cd' %}selected{% endif %}>CD</option>
                                        <option value="vinyle" {% if form.format.vars.value == 'vinyle' %}selected{% endif %}>Vinyle</option>
                                        <option value="k7" {% if form.format.vars.value == 'k7' %}selected{% endif %}>K7</option>
                                        <option value="digital" {% if form.format.vars.value == 'digital' %}selected{% endif %}>Digital</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label for="{{ form.annee.vars.id }}"><strong>Année</strong></label>
                                    <input type="number" name="{{ form.annee.vars.full_name }}" id="{{ form.annee.vars.id }}" 
                                           class="form-control" value="{{ form.annee.vars.value }}" 
                                           placeholder="Ex: 2023" min="1900" max="2100">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label for="{{ form.genre.vars.id }}"><strong>Genre</strong></label>
                                    <input type="text" name="{{ form.genre.vars.full_name }}" id="{{ form.genre.vars.id }}" 
                                           class="form-control" value="{{ form.genre.vars.value }}" 
                                           placeholder="Ex: Rock, Pop...">
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label for="{{ form.label.vars.id }}"><strong>Label</strong></label>
                                    <input type="text" name="{{ form.label.vars.full_name }}" id="{{ form.label.vars.id }}" 
                                           class="form-control" value="{{ form.label.vars.value }}" 
                                           placeholder="Ex: Universal, Sony...">
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="{{ form.description.vars.id }}"><strong>Description / Notes</strong></label>
                            <textarea name="{{ form.description.vars.full_name }}" id="{{ form.description.vars.id }}" 
                                      class="form-control" rows="3" placeholder="Informations supplémentaires...">{{ form.description.vars.value }}</textarea>
                        </div>

                        <div class="form-group">
                            <label for="{{ form.tracklist.vars.id }}"><strong><i class="fas fa-list-ol"></i> Liste des pistes</strong></label>
                            <textarea name="{{ form.tracklist.vars.full_name }}" id="{{ form.tracklist.vars.id }}" 
                                      class="form-control" rows="6" placeholder="1. Titre de la piste 1&#10;2. Titre de la piste 2&#10;...">{{ form.tracklist.vars.value }}</textarea>
                            <small class="text-muted">Une piste par ligne</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="{{ form.coverUrl.vars.id }}"><strong>URL de la pochette</strong></label>
                                    <input type="url" name="{{ form.coverUrl.vars.full_name }}" id="{{ form.coverUrl.vars.id }}" 
                                           class="form-control" value="{{ form.coverUrl.vars.value }}" 
                                           placeholder="https://...">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-upload"></i> Ou uploader une pochette</label>
                                    <div class="custom-file">
                                        <input type="file" name="cover_upload" class="custom-file-input" id="coverUpload" accept="image/*">
                                        <label class="custom-file-label" for="coverUpload" data-browse="Parcourir">Choisir un fichier...</label>
                                    </div>
                                    <small class="text-muted">Formats acceptés: JPG, PNG, GIF, WebP</small>
                                </div>
                            </div>
                        </div>

                        {% if isEdit and musique.coverUrl %}
                        <div class="form-group">
                            <label>Pochette actuelle</label>
                            <div>
                                <img src="{{ musique.coverUrl }}" alt="Pochette" class="img-thumbnail" style="max-height: 150px;">
                            </div>
                        </div>
                        {% endif %}

                        {% if not isEdit %}
                        <hr>
                        <div class="form-group">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" id="addToCollection" name="add_to_collection" value="1" checked>
                                <label class="custom-control-label" for="addToCollection">
                                    <strong>Ajouter à ma collection</strong>
                                </label>
                            </div>
                        </div>

                        <div id="collectionDetails">
                            <div class="card bg-light mb-3">
                                <div class="card-body">
                                    <h6><i class="fas fa-user"></i> Informations de ma collection</h6>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Date d'achat</label>
                                                <input type="date" name="date_achat" class="form-control" value="{{ 'now'|date('Y-m-d') }}">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Prix d'achat <i class="fas fa-euro-sign"></i></label>
                                                <input type="number" name="prix_achat" class="form-control" step="0.01" min="0" placeholder="0.00">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label><i class="fas fa-camera"></i> Photo de votre édition <small class="text-muted">(optionnel)</small></label>
                                        <div class="btn-group btn-group-sm mb-2 d-block" role="group">
                                            <button type="button" class="btn btn-outline-secondary active" id="btnUploadFile">
                                                <i class="fas fa-upload"></i> Fichier
                                            </button>
                                            <button type="button" class="btn btn-outline-secondary" id="btnUploadUrl">
                                                <i class="fas fa-link"></i> URL
                                            </button>
                                        </div>
                                        <div id="fileUploadSection">
                                            <div class="custom-file">
                                                <input type="file" name="image_perso" class="custom-file-input" id="imagePersoInput" accept="image/*">
                                                <label class="custom-file-label" for="imagePersoInput" data-browse="Parcourir">Choisir une image...</label>
                                            </div>
                                        </div>
                                        <div id="urlUploadSection" style="display: none;">
                                            <input type="url" name="image_perso_url" class="form-control" id="imagePersoUrl" placeholder="https://exemple.com/image.jpg">
                                        </div>
                                        <small class="text-muted d-block mt-1">Photo de votre CD, vinyle, collector...</small>
                                        <div id="imagePersoPreview" class="mt-2 text-center" style="display: none;">
                                            <img id="previewPersoImg" src="" class="img-thumbnail" style="max-height: 100px;">
                                        </div>
                                    </div>
                                    <div class="form-group mb-0">
                                        <label>Commentaire</label>
                                        <textarea name="commentaire_lien" class="form-control" rows="2" placeholder="Notes personnelles..."></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {% endif %}

                        <hr>
                        <div class="d-flex justify-content-between">
                            <a href="{% if isEdit %}{{ path('musique_detail', {id: musique.id}) }}{% else %}{{ path('musique_index') }}{% endif %}" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Annuler
                            </a>
                            <button type="submit" class="btn text-white" style="background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);">
                                <i class="fas fa-save"></i> {% if isEdit %}Enregistrer{% else %}Créer l'album{% endif %}
                            </button>
                        </div>
                    </form>
                    {{ form_end(form, {'render_rest': false}) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
$(document).ready(function() {
    $('#addToCollection').change(function() {
        $('#collectionDetails').toggle(this.checked);
    });

    $('#coverUpload').change(function(e) {
        var file = e.target.files[0];
        if (file) {
            $(this).next('.custom-file-label').text(file.name);
        } else {
            $(this).next('.custom-file-label').text('Choisir un fichier...');
        }
    });

    $('#btnUploadFile').click(function() {
        $(this).addClass('active');
        $('#btnUploadUrl').removeClass('active');
        $('#fileUploadSection').show();
        $('#urlUploadSection').hide();
        $('#imagePersoUrl').val('');
        $('#imagePersoPreview').hide();
    });

    $('#btnUploadUrl').click(function() {
        $(this).addClass('active');
        $('#btnUploadFile').removeClass('active');
        $('#urlUploadSection').show();
        $('#fileUploadSection').hide();
        $('#imagePersoInput').val('');
        $('#imagePersoInput').next('.custom-file-label').text('Choisir une image...');
        $('#imagePersoPreview').hide();
    });

    $('#imagePersoInput').change(function(e) {
        var file = e.target.files[0];
        if (file) {
            $(this).next('.custom-file-label').text(file.name);
            if (file.type.match('image.*')) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    $('#previewPersoImg').attr('src', e.target.result);
                    $('#imagePersoPreview').show();
                };
                reader.readAsDataURL(file);
            }
        } else {
            $(this).next('.custom-file-label').text('Choisir une image...');
            $('#imagePersoPreview').hide();
        }
    });

    $('#imagePersoUrl').on('input', function() {
        var url = $(this).val().trim();
        if (url) {
            $('#previewPersoImg').attr('src', url).on('load', function() {
                $('#imagePersoPreview').show();
            }).on('error', function() {
                $('#imagePersoPreview').hide();
            });
        } else {
            $('#imagePersoPreview').hide();
        }
    });
});
</script>
{% endblock %}

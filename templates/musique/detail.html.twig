{% extends 'base.html.twig' %}

{% block title %}{{ musique.artiste }} - {{ musique.titre }} - BDD-Musique{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <a href="{{ path('musique_list') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
                {% if is_granted('IS_AUTHENTICATED_REMEMBERED') and app.user.canRegisterInSection('musique') %}
                <div>
                    <a href="{{ path('musique_edit', {id: musique.id}) }}" class="btn btn-outline-primary">
                        <i class="fas fa-edit"></i> Modifier
                    </a>
                    <form method="post" action="{{ path('musique_delete', {id: musique.id}) }}" class="d-inline" onsubmit="return confirm('Confirmer la suppression ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ musique.id) }}">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="fas fa-trash"></i> Supprimer
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>

            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);">
                    <h4 class="mb-0 text-white">{{ musique.artiste }} - {{ musique.titre }}</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center">
                            <img src="{{ musique.mainImage ?: '/images/musique-default.svg' }}" class="img-fluid rounded shadow mb-3" style="max-height: 350px;">
                            <div>
                                <span class="badge badge-danger mr-1">
                                    {{ musique.format == 'vinyle' ? 'Vinyle' : musique.format == 'k7' ? 'K7' : musique.format == 'digital' ? 'Digital' : 'CD' }}
                                </span>
                                <span class="badge badge-secondary">
                                    {{ musique.type == 'single' ? 'Single' : musique.type == 'ep' ? 'EP' : musique.type == 'compilation' ? 'Compilation' : 'Album' }}
                                </span>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <p><strong><i class="fas fa-calendar"></i> Année:</strong> {{ musique.annee ?: '-' }}</p>
                                    <p><strong><i class="fas fa-tag"></i> Label:</strong> {{ musique.label ?: '-' }}</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong><i class="fas fa-guitar"></i> Genre:</strong> {{ musique.genre ?: '-' }}</p>
                                </div>
                            </div>
                            {% if musique.description %}
                            <div class="mb-3">
                                <h6>Notes</h6>
                                <p>{{ musique.description|nl2br }}</p>
                            </div>
                            {% endif %}

                            {% if musique.tracklist %}
                            <div class="mb-3">
                                <h6><i class="fas fa-list-ol"></i> Liste des pistes</h6>
                                <div class="bg-light p-2 rounded" style="max-height: 200px; overflow-y: auto;">
                                    <pre class="mb-0 small" style="white-space: pre-wrap;">{{ musique.tracklist }}</pre>
                                </div>
                            </div>
                            {% endif %}
                        </div>
                    </div>

                    <hr>
                    <h5><i class="fas fa-users"></i> Propriétaires</h5>
                    {% if owners|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Utilisateur</th>
                                        <th>Date d'achat</th>
                                        <th>Prix</th>
                                        <th>Commentaire</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for owner in owners %}
                                    <tr>
                                        <td>{{ owner.user.name }} {{ owner.user.lastname }}</td>
                                        <td>{{ owner.dateAchat ? owner.dateAchat|date('d/m/Y') : '-' }}</td>
                                        <td>{{ owner.prixAchat ? owner.prixAchat ~ ' €' : '-' }}</td>
                                        <td>{{ owner.commentaire ?: '-' }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="text-muted">Personne ne possède cet album.</p>
                    {% endif %}

                    {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                    <div class="mt-3">
                        {% if userLinks|length == 0 %}
                            <a href="{{ path('musique_add_owner', {id: musique.id}) }}" class="btn btn-success">
                                <i class="fas fa-plus"></i> Ajouter à ma collection
                            </a>
                        {% else %}
                            {% for link in userLinks %}
                                <a href="{{ path('musique_edit_owner', {id: musique.id, lienId: link.id}) }}" class="btn btn-outline-primary">
                                    <i class="fas fa-edit"></i> Modifier ma collection
                                </a>
                            {% endfor %}
                        {% endif %}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

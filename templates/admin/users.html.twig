{% extends 'base.html.twig' %}

{% block title %}Administration - Utilisateurs{% endblock %}

{% block body %}
<div id="acceuilSite">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 font-weight-bold text-danger">
            <i class="fas fa-users-cog"></i> Gestion des utilisateurs
        </h1>
        <a href="{{ path('index') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle"></i> {{ message }}
            <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
    {% endfor %}

    <div class="card">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0"><i class="fas fa-shield-alt"></i> Permissions d'enregistrement par section</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>Utilisateur</th>
                            <th>Email</th>
                            <th>Rôle</th>
                            <th class="text-center">Sections autorisées</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    {% if user.logo %}
                                        <img src="{{ asset('uploads/avatars/' ~ user.logo) }}" class="rounded-circle mr-2" style="width: 32px; height: 32px; object-fit: cover;">
                                    {% else %}
                                        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center mr-2" style="width: 32px; height: 32px; font-size: 12px;">
                                            {{ user.initiales }}
                                        </div>
                                    {% endif %}
                                    <strong>{{ user.fullName }}</strong>
                                </div>
                            </td>
                            <td>{{ user.email }}</td>
                            <td>
                                {% if 'ROLE_ADMIN' in user.roles %}
                                    <span class="badge badge-danger">Admin</span>
                                {% else %}
                                    <span class="badge badge-secondary">Utilisateur</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if 'ROLE_ADMIN' in user.roles %}
                                    <span class="badge badge-success"><i class="fas fa-infinity"></i> Toutes (Admin)</span>
                                {% elseif user.sectionsEnregistrement is null %}
                                    <span class="badge badge-success"><i class="fas fa-check-double"></i> Toutes</span>
                                {% elseif user.sectionsEnregistrement is empty %}
                                    <span class="badge badge-danger"><i class="fas fa-ban"></i> Aucune</span>
                                {% else %}
                                    {% for sectionKey in user.sectionsEnregistrement %}
                                        <span class="badge badge-info">{{ sections[sectionKey] ?? sectionKey }}</span>
                                    {% endfor %}
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if user != app.user %}
                                    <form action="{{ path('admin_toggle_admin', {id: user.id}) }}" method="post" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle-admin-' ~ user.id) }}">
                                        {% if 'ROLE_ADMIN' in user.roles %}
                                            <button type="submit" class="btn btn-sm btn-outline-warning" onclick="return confirm('Retirer les droits admin à {{ user.fullName }} ?')">
                                                <i class="fas fa-user-minus"></i> Retirer admin
                                            </button>
                                        {% else %}
                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                <i class="fas fa-user-plus"></i> Rendre admin
                                            </button>
                                        {% endif %}
                                    </form>
                                    {% if 'ROLE_ADMIN' not in user.roles %}
                                    <a href="{{ path('admin_user_permissions', {id: user.id}) }}" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i> Permissions
                                    </a>
                                    {% endif %}
                                {% else %}
                                    <span class="text-muted small"><i class="fas fa-user-shield"></i> Vous</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="fas fa-info-circle"></i> Légende</h5>
        </div>
        <div class="card-body">
            <div class="row">
                {% for key, label in sections %}
                <div class="col-md-3 mb-2">
                    <span class="badge badge-info">{{ label }}</span>
                    <small class="text-muted ml-2">{{ key }}</small>
                </div>
                {% endfor %}
            </div>
            <hr>
            <p class="mb-0 text-muted small">
                <i class="fas fa-info-circle"></i> 
                <strong>Toutes</strong> = L'utilisateur peut enregistrer dans toutes les sections<br>
                <strong>Aucune</strong> = L'utilisateur ne peut enregistrer nulle part (lecture seule)<br>
                <strong>Admin</strong> = Les administrateurs ont toujours accès à tout
            </p>
        </div>
    </div>
</div>
{% endblock %}

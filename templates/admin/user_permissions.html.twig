{% extends 'base.html.twig' %}

{% block title %}Permissions - {{ user.fullName }}{% endblock %}

{% block body %}
<div id="acceuilSite">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 font-weight-bold text-danger">
            <i class="fas fa-user-shield"></i> Permissions de {{ user.fullName }}
        </h1>
        <a href="{{ path('admin_users') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fas fa-edit"></i> Sections d'enregistrement autorisées</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <p class="text-muted mb-4">
                            Sélectionnez les sections dans lesquelles <strong>{{ user.fullName }}</strong> peut enregistrer du contenu.
                            Si aucune section n'est cochée, l'utilisateur sera en lecture seule.
                        </p>

                        <div class="row">
                            {% for key, label in sections %}
                            <div class="col-md-6 mb-3">
                                <div class="custom-control custom-switch">
                                    <input type="checkbox" 
                                           class="custom-control-input" 
                                           id="section_{{ key }}" 
                                           name="sections[]" 
                                           value="{{ key }}"
                                           {% if user.sectionsEnregistrement is null or key in (user.sectionsEnregistrement ?? []) %}checked{% endif %}>
                                    <label class="custom-control-label" for="section_{{ key }}">
                                        {% if key == 'books' %}
                                            <i class="fas fa-book text-primary"></i>
                                        {% elseif key == 'magazines' %}
                                            <i class="fas fa-newspaper text-success"></i>
                                        {% elseif key == 'brick' %}
                                            <i class="fas fa-cubes text-warning"></i>
                                        {% elseif key == 'games' %}
                                            <i class="fas fa-gamepad" style="color: #6f42c1;"></i>
                                        {% endif %}
                                        <strong>{{ label }}</strong>
                                    </label>
                                </div>
                            </div>
                            {% endfor %}
                        </div>

                        <hr>

                        <div class="d-flex justify-content-between">
                            <div>
                                <button type="button" class="btn btn-outline-success btn-sm" onclick="selectAll()">
                                    <i class="fas fa-check-double"></i> Tout sélectionner
                                </button>
                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="deselectAll()">
                                    <i class="fas fa-times"></i> Tout désélectionner
                                </button>
                            </div>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-save"></i> Enregistrer
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="fas fa-user"></i> Informations</h5>
                </div>
                <div class="card-body text-center">
                    {% if user.logo %}
                        <img src="{{ asset('uploads/avatars/' ~ user.logo) }}" class="rounded-circle mb-3" style="width: 100px; height: 100px; object-fit: cover;">
                    {% else %}
                        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 100px; height: 100px; font-size: 36px;">
                            {{ user.initiales }}
                        </div>
                    {% endif %}
                    <h5>{{ user.fullName }}</h5>
                    <p class="text-muted mb-1">{{ user.email }}</p>
                    <p class="text-muted mb-0">@{{ user.username }}</p>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Aide</h5>
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-2">
                        <i class="fas fa-check text-success"></i> <strong>Coché</strong> = L'utilisateur peut ajouter et modifier du contenu
                    </p>
                    <p class="small text-muted mb-2">
                        <i class="fas fa-times text-danger"></i> <strong>Décoché</strong> = Lecture seule pour cette section
                    </p>
                    <p class="small text-muted mb-0">
                        <i class="fas fa-eye text-info"></i> Tout le monde peut <strong>voir</strong> tout le contenu
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function selectAll() {
    document.querySelectorAll('input[name="sections[]"]').forEach(cb => cb.checked = true);
}
function deselectAll() {
    document.querySelectorAll('input[name="sections[]"]').forEach(cb => cb.checked = false);
}
</script>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Admin — Stores{% endblock %}

{% block body %}
<div id="acceuilSite">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h1 class="display-5 font-weight-bold text-danger mb-0">
            <i class="fas fa-store"></i> Stores (dématérialisé)
        </h1>
        <div>
            <a href="{{ path('admin_game_index') }}" class="btn btn-outline-secondary btn-sm"><i class="fas fa-home"></i> Références jeux</a>
            <a href="{{ path('admin_game_store_new') }}" class="btn btn-danger btn-sm"><i class="fas fa-plus"></i> Nouveau store</a>
        </div>
    </div>

    {% for label, msgs in app.flashes %}
        {% for msg in msgs %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show">{{ msg }}
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>Position</th>
                            <th>Nom</th>
                            <th>Icône</th>
                            <th class="text-center">Actif</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for s in stores %}
                        <tr>
                            <td>{{ s.position }}</td>
                            <td>{{ s.nom }}</td>
                            <td>{% if s.icone %}<i class="{{ s.icone }}"></i> <small class="text-muted">{{ s.icone }}</small>{% else %}—{% endif %}</td>
                            <td class="text-center">{% if s.actif %}<span class="badge badge-success">oui</span>{% else %}<span class="badge badge-secondary">non</span>{% endif %}</td>
                            <td class="text-right">
                                <a href="{{ path('admin_game_store_edit', {id: s.id}) }}" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="5" class="text-center text-muted py-4">Aucun store.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

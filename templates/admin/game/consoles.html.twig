{% extends 'base.html.twig' %}

{% block title %}Admin — Consoles{% endblock %}

{% block body %}
<div id="acceuilSite">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h1 class="display-5 font-weight-bold text-danger mb-0">
            <i class="fas fa-gamepad"></i> Consoles
        </h1>
        <div>
            <a href="{{ path('admin_game_index') }}" class="btn btn-outline-secondary btn-sm"><i class="fas fa-home"></i> Références jeux</a>
            <a href="{{ path('admin_game_console_aliases') }}" class="btn btn-outline-danger btn-sm"><i class="fas fa-exchange-alt"></i> Mapping</a>
            <a href="{{ path('admin_game_console_new') }}" class="btn btn-danger btn-sm"><i class="fas fa-plus"></i> Nouvelle console</a>
        </div>
    </div>

    {% for label, msgs in app.flashes %}
        {% for msg in msgs %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show">{{ msg }}
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>Position</th>
                            <th>IGDB</th>
                            <th>Code</th>
                            <th>Nom</th>
                            <th>Icône</th>
                            <th>Fond</th>
                            <th class="text-center">Actif</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for c in consoles %}
                        <tr>
                            <td>{{ c.position }}</td>
                            <td>{% if c.igdbPlatformId %}<small class="text-muted">{{ c.igdbPlatformId }}</small>{% else %}—{% endif %}</td>
                            <td><code>{{ c.code }}</code></td>
                            <td>{{ c.nom }}</td>
                            <td>
                                {% if c.icone %}
                                    <span class="badge badge-secondary"><i class="{{ c.icone }}"></i></span>
                                    <small class="text-muted ml-1">{{ c.icone }}</small>
                                {% else %}—{% endif %}
                            </td>
                            <td>
                                {% if c.couleur %}
                                    <span class="d-inline-block rounded border" style="width:28px;height:28px;background:{{ c.couleur }};vertical-align:middle;" title="{{ c.couleur }}"></span>
                                    <small class="text-muted">{{ c.couleur }}</small>
                                {% else %}—{% endif %}
                            </td>
                            <td class="text-center">{% if c.actif %}<span class="badge badge-success">oui</span>{% else %}<span class="badge badge-secondary">non</span>{% endif %}</td>
                            <td class="text-right">
                                <a href="{{ path('admin_game_console_edit', {id: c.id}) }}" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                                <form action="{{ path('admin_game_console_delete', {id: c.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Supprimer cette console ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete-console-' ~ c.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="8" class="text-center text-muted py-4">Aucune console. Importez via SQL ou la commande de migration.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

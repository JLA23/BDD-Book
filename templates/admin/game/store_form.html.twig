{% extends 'base.html.twig' %}

{% block title %}Admin — {% if store %}Modifier{% else %}Nouveau{% endif %} store{% endblock %}

{% block body %}
<div id="acceuilSite" class="col-lg-8">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 font-weight-bold text-danger">
            {% if store %}<i class="fas fa-edit"></i> Modifier{% else %}<i class="fas fa-plus"></i> Nouveau{% endif %} store
        </h1>
        <a href="{{ path('admin_game_stores') }}" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left"></i> Liste</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="post">
                <div class="form-group">
                    <label for="nom">Nom <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="nom" name="nom" maxlength="100" required
                           value="{{ store ? store.nom : '' }}" placeholder="Steam">
                    <small class="text-muted">Doit correspondre au libellé envoyé par les formulaires (<code>lien_user_game.store</code>).</small>
                </div>
                <div class="form-group">
                    <label for="icone">Icône (classes FontAwesome)</label>
                    <input type="text" class="form-control font-monospace" id="icone" name="icone" maxlength="100"
                           value="{{ store ? store.icone : '' }}" placeholder="fab fa-steam">
                </div>
                <div class="form-group">
                    <label for="position">Position</label>
                    <input type="number" class="form-control" id="position" name="position" value="{{ store ? store.position : 0 }}">
                </div>
                <div class="custom-control custom-checkbox mb-3">
                    <input type="checkbox" class="custom-control-input" id="actif" name="actif" value="1" {% if not store or store.actif %}checked{% endif %}>
                    <label class="custom-control-label" for="actif">Store actif</label>
                </div>
                <button type="submit" class="btn btn-danger"><i class="fas fa-save"></i> Enregistrer</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Collections - BDD-Brick{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="card shadow-sm">
        <div class="card-header" style="background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-white"><i class="fas fa-layer-group"></i> Collections / Thèmes</h5>
                {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                <a href="{{ path('brick_collection_new') }}" class="btn btn-light btn-sm">
                    <i class="fas fa-plus"></i> Nouvelle collection
                </a>
                {% endif %}
            </div>
        </div>
        <div class="card-body">
            {% if collections|length > 0 %}
            <div class="row">
                {% for collection in collections %}
                <div class="col-md-4 col-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{ collection.nom }}</h5>
                            <p class="card-text text-muted small">{{ collection.sets|length }} set(s)</p>
                        </div>
                        <div class="card-footer bg-white">
                            <a href="{{ path('brick_list', {collection: collection.id}) }}" class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-eye"></i> Voir les sets
                            </a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="alert alert-info">Aucune collection.</div>
            {% endif %}
        </div>
        <div class="card-footer">
            <a href="{{ path('brick_list') }}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{% if isEdit %}Modifier{% else %}Nouveau{% endif %} set - BDD-Brick{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            {% if duplicateWarning %}
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-triangle"></i> <strong>{{ duplicateWarning.message }}</strong>
                <p class="mb-0 mt-2">
                    <a href="{{ path('brick_detail', {id: duplicateWarning.set.id}) }}" class="alert-link">
                        Voir le set existant: {{ duplicateWarning.set.nom }} ({{ duplicateWarning.set.reference }})
                    </a>
                </p>
            </div>
            {% endif %}

            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);">
                    <h5 class="mb-0 text-white">
                        <i class="fas fa-{% if isEdit %}edit{% else %}plus{% endif %}"></i>
                        {% if isEdit %}Modifier le set{% else %}Nouveau set{% endif %}
                    </h5>
                </div>
                <div class="card-body">
                    {% if prefillImages is defined and prefillImages|length > 0 %}
                    <div class="alert alert-info mb-4">
                        <strong><i class="fas fa-info-circle"></i> Import depuis API</strong>
                        <p class="mb-2 small">{{ prefillImages|length }} image(s) seront automatiquement ajoutées.</p>
                        <div class="d-flex flex-wrap">
                            {% for img in prefillImages %}
                            <img src="{{ img.url }}" alt="Aperçu {{ loop.index }}" class="mr-2 mb-2 rounded border" style="height: 60px; object-fit: contain;">
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                    
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                {{ form_label(form.nom) }}
                                {{ form_widget(form.nom) }}
                                {{ form_errors(form.nom) }}
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                {{ form_label(form.reference) }}
                                {{ form_widget(form.reference) }}
                                {{ form_errors(form.reference) }}
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                {{ form_label(form.ean) }}
                                {{ form_widget(form.ean) }}
                                {{ form_errors(form.ean) }}
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                {{ form_label(form.marque) }}
                                <div class="input-group">
                                    {{ form_widget(form.marque) }}
                                    <div class="input-group-append">
                                        <button type="button" class="btn btn-outline-secondary" data-toggle="modal" data-target="#newMarqueModal">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                                {{ form_errors(form.marque) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                {{ form_label(form.collection) }}
                                <div class="input-group">
                                    {{ form_widget(form.collection) }}
                                    <div class="input-group-append">
                                        <button type="button" class="btn btn-outline-secondary" data-toggle="modal" data-target="#newCollectionModal">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                                {{ form_errors(form.collection) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                {{ form_label(form.prix) }}
                                <div class="input-group">
                                    {{ form_widget(form.prix) }}
                                    <div class="input-group-append">
                                        <span class="input-group-text">€</span>
                                    </div>
                                </div>
                                {{ form_errors(form.prix) }}
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                {{ form_label(form.annee) }}
                                {{ form_widget(form.annee) }}
                                {{ form_errors(form.annee) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                {{ form_label(form.nbPieces) }}
                                {{ form_widget(form.nbPieces) }}
                                {{ form_errors(form.nbPieces) }}
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        {{ form_label(form.description) }}
                        {{ form_widget(form.description) }}
                        {{ form_errors(form.description) }}
                    </div>
                    
                    <hr>
                    <h5><i class="fas fa-images"></i> Images</h5>
                    
                    {% if isEdit %}
                    <div class="mb-3">
                        {% if set.images|length > 0 %}
                        <div class="d-flex flex-wrap mb-2">
                            {% for image in set.images %}
                            <div class="position-relative m-1">
                                <img src="{{ image.displayUrl }}" class="rounded border {% if loop.first %}border-warning{% endif %}" style="height: 80px; width: 80px; object-fit: cover;">
                                {% if loop.first %}
                                <span class="badge badge-warning position-absolute" style="top: -5px; left: -5px; font-size: 8px;"><i class="fas fa-star"></i></span>
                                {% endif %}
                            </div>
                            {% endfor %}
                        </div>
                        <a href="{{ path('brick_images', {id: set.id}) }}" class="btn btn-sm btn-outline-info">
                            <i class="fas fa-images"></i> Gérer les images ({{ set.images|length }})
                        </a>
                        {% else %}
                        <p class="text-muted">Aucune image</p>
                        <a href="{{ path('brick_images', {id: set.id}) }}" class="btn btn-sm btn-outline-info">
                            <i class="fas fa-plus"></i> Ajouter des images
                        </a>
                        {% endif %}
                    </div>
                    {% else %}
                    <div id="pendingImagesSection" class="mb-3">
                        <label class="d-block mb-2">Images en attente d'ajout <span id="pendingCount" class="badge badge-info">{{ prefillImages|length }}</span> <small class="text-muted">(glisser-déposer pour réordonner, la première = image principale)</small></label>
                        <div id="pendingImagesGrid" class="d-flex flex-wrap mb-2">
                            {% for img in prefillImages %}
                            <div class="pending-image-item position-relative m-1" data-index="{{ loop.index0 }}" data-url="{{ img.url }}">
                                <div class="position-relative">
                                    <img src="{{ img.url }}" class="rounded border {% if loop.first %}border-warning{% endif %}" style="height: 80px; width: 80px; object-fit: cover; cursor: move;">
                                    {% if loop.first %}
                                    <span class="badge badge-warning position-absolute main-image-badge" style="top: -5px; left: -5px; font-size: 8px;"><i class="fas fa-star"></i></span>
                                    {% endif %}
                                    <button type="button" class="btn btn-sm btn-danger position-absolute remove-pending-image" style="top: -5px; right: -5px; padding: 0 5px; font-size: 12px;">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                                <small class="d-block text-center text-muted" style="font-size: 10px;">{{ img.source|default('API') }}</small>
                            </div>
                            {% endfor %}
                        </div>
                        
                        <div id="imageUrlsContainer">
                            {% for img in prefillImages %}
                            <input type="hidden" name="image_urls[]" value="{{ img.url }}">
                            {% endfor %}
                        </div>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-images"></i> Ajouter des images <small class="text-muted">(optionnel)</small></label>
                        <div class="btn-group btn-group-sm mb-2" role="group">
                            <button type="button" class="btn btn-outline-secondary active" id="btnUploadFile">
                                <i class="fas fa-upload"></i> Fichier
                            </button>
                            <button type="button" class="btn btn-outline-secondary" id="btnUploadUrl">
                                <i class="fas fa-link"></i> URL
                            </button>
                        </div>
                        <div id="fileUploadSection">
                            <div class="custom-file">
                                <input type="file" name="uploaded_images[]" class="custom-file-input" id="uploadedImagesInput" multiple accept="image/*">
                                <label class="custom-file-label" for="uploadedImagesInput" data-browse="Parcourir">Choisir une image...</label>
                            </div>
                        </div>
                        <div id="urlUploadSection" style="display: none;">
                            <div class="input-group input-group-sm">
                                <input type="url" id="addImageUrl" class="form-control" placeholder="https://...">
                                <div class="input-group-append">
                                    <button type="button" id="addImageUrlBtn" class="btn btn-outline-secondary">
                                        <i class="fas fa-plus"></i> Ajouter
                                    </button>
                                </div>
                            </div>
                        </div>
                        <small class="text-muted">Vous pouvez sélectionner plusieurs fichiers ou ajouter des images par URL</small>
                    </div>
                    
                    <hr>
                    <h5><i class="fas fa-user"></i> Ma collection</h5>
                    
                    <div class="form-group">
                        <div class="custom-control custom-checkbox">
                            <input type="checkbox" class="custom-control-input" id="addToCollection" name="add_to_collection" value="1" checked>
                            <label class="custom-control-label" for="addToCollection">Ajouter ce set à ma collection</label>
                        </div>
                    </div>
                    
                    <div id="collectionDetails">
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6><i class="fas fa-user"></i> Informations de ma collection</h6>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Date d'acquisition</label>
                                            <input type="date" name="date_achat" class="form-control form-control-sm" value="{{ "now"|date("Y-m-d") }}">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Prix d'achat <i class="fas fa-euro-sign"></i></label>
                                            <input type="number" name="prix_achat" class="form-control form-control-sm" step="0.01" min="0" placeholder="0.00">
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Commentaire</label>
                                    <textarea name="commentaire_lien" class="form-control form-control-sm" rows="2" placeholder="Notes personnelles..."></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                    
                    <hr>
                    
                    <div class="d-flex justify-content-between">
                        <a href="{% if isEdit %}{{ path('brick_detail', {id: set.id}) }}{% else %}{{ path('brick_list') }}{% endif %}" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Annuler
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> {% if isEdit %}Enregistrer{% else %}Créer le set{% endif %}
                        </button>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal nouvelle marque -->
<div class="modal fade" id="newMarqueModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);">
                <h5 class="modal-title text-white"><i class="fas fa-trademark"></i> Nouvelle marque</h5>
                <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="newMarqueName">Nom de la marque</label>
                    <input type="text" id="newMarqueName" class="form-control" placeholder="Ex: LEGO, Mega Bloks...">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-success" id="createMarqueBtn"><i class="fas fa-plus"></i> Créer</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal nouvelle collection -->
<div class="modal fade" id="newCollectionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);">
                <h5 class="modal-title text-white"><i class="fas fa-layer-group"></i> Nouvelle collection</h5>
                <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="newCollectionName">Nom de la collection</label>
                    <input type="text" id="newCollectionName" class="form-control" placeholder="Ex: Star Wars, Technic...">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-success" id="createCollectionBtn"><i class="fas fa-plus"></i> Créer</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
$(document).ready(function() {
    // Toggle collection details
    $('#addToCollection').change(function() {
        $('#collectionDetails').toggle(this.checked);
    });

    // Met à jour les badges principale, les bordures, et réordonne les inputs cachés
    function updatePendingImagesVisuals() {
        var items = $('#pendingImagesGrid .pending-image-item');
        items.each(function(i) {
            var $item = $(this);
            var $img = $item.find('img');
            var $badge = $item.find('.main-image-badge');
            if (i === 0) {
                $img.addClass('border-warning');
                if ($badge.length === 0) {
                    $img.before('<span class="badge badge-warning position-absolute main-image-badge" style="top: -5px; left: -5px; font-size: 8px;"><i class="fas fa-star"></i></span>');
                }
            } else {
                $img.removeClass('border-warning');
                $badge.remove();
            }
        });

        // Réordonner les inputs cachés selon l'ordre visuel
        var $container = $('#imageUrlsContainer').empty();
        items.each(function() {
            var url = $(this).data('url');
            $container.append('<input type="hidden" name="image_urls[]" value="' + url + '">');
        });
    }

    // Initialiser SortableJS sur la grille d'images en attente
    var sortableEl = document.getElementById('pendingImagesGrid');
    if (sortableEl) {
        new Sortable(sortableEl, {
            animation: 150,
            onEnd: function() {
                updatePendingImagesVisuals();

                // Synchroniser le nouvel ordre avec la session
                var urls = [];
                $('#pendingImagesGrid .pending-image-item').each(function() {
                    urls.push($(this).data('url'));
                });
                $.ajax({
                    url: '{{ path("brick_api_reorder_pending_images") }}',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ urls: urls })
                });
            }
        });
    }

    // Remove pending image
    $(document).on('click', '.remove-pending-image', function() {
        var item = $(this).closest('.pending-image-item');
        var url = item.data('url');

        $.ajax({
            url: '{{ path("brick_api_remove_pending_image") }}',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ url: url }),
            success: function(response) {
                if (response.success) {
                    item.fadeOut(200, function() {
                        $(this).remove();
                        updatePendingImagesVisuals();
                        $('#pendingCount').text(response.count);
                    });
                }
            }
        });
    });

    // Add image by URL
    $('#addImageUrlBtn').click(function() {
        var url = $('#addImageUrl').val().trim();
        if (!url) { alert('Veuillez saisir une URL'); return; }

        // Add hidden input for form submission
        $('#imageUrlsContainer').append('<input type="hidden" name="image_urls[]" value="' + url + '">');

        // Add visual element
        var count = $('#pendingImagesGrid .pending-image-item').length;
        var isFirst = (count === 0);
        var html = '<div class="pending-image-item position-relative m-1" data-index="' + count + '" data-url="' + url + '">' +
            '<div class="position-relative">' +
            '<img src="' + url + '" class="rounded border ' + (isFirst ? 'border-warning' : '') + '" style="height: 80px; width: 80px; object-fit: cover; cursor: move;">' +
            (isFirst ? '<span class="badge badge-warning position-absolute main-image-badge" style="top: -5px; left: -5px; font-size: 8px;"><i class="fas fa-star"></i></span>' : '') +
            '<button type="button" class="btn btn-sm btn-danger position-absolute remove-pending-image" style="top: -5px; right: -5px; padding: 0 5px; font-size: 12px;">' +
            '<i class="fas fa-times"></i></button>' +
            '</div>' +
            '<small class="d-block text-center text-muted" style="font-size: 10px;">Manuel</small></div>';
        $('#pendingImagesGrid').append(html);
        $('#pendingCount').text(count + 1);
        $('#addImageUrl').val('');

        // Also update session
        $.ajax({
            url: '{{ path("brick_api_add_pending_image") }}',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ url: url })
        });
    });

    $('#addImageUrl').keypress(function(e) {
        if (e.which == 13) { e.preventDefault(); $('#addImageUrlBtn').click(); }
    });

    // Toggle fichier / URL pour ajout d'images
    $('#btnUploadFile').click(function() {
        $(this).addClass('active');
        $('#btnUploadUrl').removeClass('active');
        $('#fileUploadSection').show();
        $('#urlUploadSection').hide();
        $('#addImageUrl').val('');
    });

    $('#btnUploadUrl').click(function() {
        $(this).addClass('active');
        $('#btnUploadFile').removeClass('active');
        $('#urlUploadSection').show();
        $('#fileUploadSection').hide();
        $('#uploadedImagesInput').val('');
        $('.custom-file-label').text('Choisir une image...');
    });

    // Mise à jour du label custom-file
    $('#uploadedImagesInput').change(function(e) {
        var files = e.target.files;
        if (files && files.length > 0) {
            var text = files.length === 1 ? files[0].name : files.length + ' fichiers sélectionnés';
            $(this).next('.custom-file-label').text(text);
        } else {
            $(this).next('.custom-file-label').text('Choisir une image...');
        }
    });

    // Create marque
    $('#createMarqueBtn').click(function() {
        var nom = $('#newMarqueName').val().trim();
        if (!nom) { alert('Veuillez saisir un nom'); return; }
        var btn = $(this);
        btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');
        $.ajax({
            url: '{{ path("brick_api_marque_create") }}',
            method: 'POST',
            data: { nom: nom },
            success: function(response) {
                if (response.success) {
                    var select = $('#{{ form.marque.vars.id }}');
                    if (response.exists) {
                        // Sélectionner l'existant
                        select.val(response.id);
                        alert('Cette marque existe déjà, elle a été sélectionnée.');
                    } else {
                        // Ajouter et sélectionner la nouvelle
                        select.append($('<option>', { value: response.id, text: response.nom, selected: true }));
                    }
                    $('#newMarqueModal').modal('hide');
                    $('#newMarqueName').val('');
                }
                btn.prop('disabled', false).html('<i class="fas fa-plus"></i> Créer');
            },
            error: function() { alert('Erreur'); btn.prop('disabled', false).html('<i class="fas fa-plus"></i> Créer'); }
        });
    });

    // Create collection
    $('#createCollectionBtn').click(function() {
        var nom = $('#newCollectionName').val().trim();
        if (!nom) { alert('Veuillez saisir un nom'); return; }
        var btn = $(this);
        btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');
        $.ajax({
            url: '{{ path("brick_api_collection_create") }}',
            method: 'POST',
            data: { nom: nom },
            success: function(response) {
                if (response.success) {
                    var select = $('#{{ form.collection.vars.id }}');
                    if (response.exists) {
                        // Sélectionner l'existant
                        select.val(response.id);
                        alert('Cette collection existe déjà, elle a été sélectionnée.');
                    } else {
                        // Ajouter et sélectionner la nouvelle
                        select.append($('<option>', { value: response.id, text: response.nom, selected: true }));
                    }
                    $('#newCollectionModal').modal('hide');
                    $('#newCollectionName').val('');
                }
                btn.prop('disabled', false).html('<i class="fas fa-plus"></i> Créer');
            },
            error: function() { alert('Erreur'); btn.prop('disabled', false).html('<i class="fas fa-plus"></i> Créer'); }
        });
    });
});
</script>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Marques - BDD-Brick{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="card shadow-sm">
        <div class="card-header" style="background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-white"><i class="fas fa-trademark"></i> Marques</h5>
                {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                <a href="{{ path('brick_marque_new') }}" class="btn btn-light btn-sm">
                    <i class="fas fa-plus"></i> Nouvelle marque
                </a>
                {% endif %}
            </div>
        </div>
        <div class="card-body">
            {% if marques|length > 0 %}
            <div class="row">
                {% for marque in marques %}
                <div class="col-md-3 col-6 mb-3">
                    <div class="card h-100 text-center">
                        <div class="card-body">
                            <h5 class="card-title">{{ marque.nom }}</h5>
                            <p class="card-text text-muted small">{{ marque.sets|length }} set(s)</p>
                            {% if marque.siteWeb %}
                            <a href="{{ marque.siteWeb }}" target="_blank" class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-external-link-alt"></i> Site
                            </a>
                            {% endif %}
                        </div>
                        <div class="card-footer bg-white">
                            <a href="{{ path('brick_list', {marque: marque.id}) }}" class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-eye"></i> Voir les sets
                            </a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="alert alert-info">Aucune marque.</div>
            {% endif %}
        </div>
        <div class="card-footer">
            <a href="{{ path('brick_list') }}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>
</div>
{% endblock %}

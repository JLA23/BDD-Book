{% extends 'base.html.twig' %}

{% block title %}Modifier ma possession - {{ set.nom }}{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);">
                    <h5 class="mb-0 text-white">
                        <i class="fas fa-edit"></i> Modifier ma possession
                    </h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <img src="{{ set.mainImageUrl }}" alt="{{ set.nom }}" class="img-fluid rounded" style="max-height: 150px;">
                        <h5 class="mt-2">{{ set.nom }}</h5>
                        <span class="badge badge-warning">{{ set.reference }}</span>
                        <p class="text-muted mt-2 mb-0">
                            <i class="fas fa-user"></i> {{ lien.user.name }} {{ lien.user.lastName }}
                        </p>
                    </div>
                    
                    <form method="post">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-calendar"></i> Date d'acquisition</label>
                                    <input type="date" name="date_achat" class="form-control" 
                                           value="{{ lien.dateAchat ? lien.dateAchat|date('Y-m-d') : '' }}">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Prix d'achat <i class="fas fa-euro-sign"></i></label>
                                    <input type="number" name="prix_achat" class="form-control" step="0.01" 
                                           value="{{ lien.prixAchat }}" placeholder="0.00">
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label><i class="fas fa-comment"></i> Commentaire</label>
                            <textarea name="commentaire" class="form-control" rows="3">{{ lien.commentaire }}</textarea>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('brick_detail', {id: set.id}) }}" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save"></i> Enregistrer
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

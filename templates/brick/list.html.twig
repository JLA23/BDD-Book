{% extends 'base.html.twig' %}

{% block title %}BDD-Brick - Liste des sets{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="card mb-4">
        <div class="card-header" style="background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-white">
                    <i class="fas fa-cubes"></i> BDD-Brick
                </h5>
                {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                <div>
                    <a href="{{ path('brick_search_reference') }}" class="btn btn-light btn-sm mr-2">
                        <i class="fas fa-search"></i> Rechercher par référence
                    </a>
                    <a href="{{ path('brick_new') }}" class="btn btn-success btn-sm">
                        <i class="fas fa-plus"></i> Ajouter un set
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
        <div class="card-body">
            <form action="{{ path('brick_list') }}" method="get" class="mb-3">
                <div class="row">
                    <div class="col-md-3 mb-2">
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-white"><i class="fas fa-search text-primary"></i></span>
                            </div>
                            <input type="text" name="search" class="form-control" value="{{ search }}" placeholder="Nom ou référence...">
                        </div>
                    </div>
                    <div class="col-md-2 mb-2">
                        <select name="marque" class="form-control">
                            <option value="">Toutes les marques</option>
                            {% for marque in marques %}
                                <option value="{{ marque.id }}" {% if selectedMarque == marque.id %}selected{% endif %}>
                                    {{ marque.nom }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3 mb-2">
                        <select name="collection" class="form-control">
                            <option value="">Toutes les collections</option>
                            {% for collection in collections %}
                                <option value="{{ collection.id }}" {% if selectedCollection == collection.id %}selected{% endif %}>
                                    {{ collection.nom }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2 mb-2">
                        <select name="user" class="form-control">
                            <option value="">Tous les propriétaires</option>
                            {% for user in users %}
                                <option value="{{ user.id }}" {% if selectedUser == user.id %}selected{% endif %}>
                                    {{ user.name }} {{ user.lastName }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2 mb-2">
                        <button type="submit" class="btn btn-primary btn-block">
                            <i class="fas fa-filter"></i> Filtrer
                        </button>
                    </div>
                </div>
            </form>
            
            <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">
                    <i class="fas fa-cubes"></i> {{ pagination.getTotalItemCount }} set(s) trouvé(s)
                </small>
                <div>
                    <a href="{{ path('brick_marques') }}" class="btn btn-outline-secondary btn-sm mr-1">
                        <i class="fas fa-trademark"></i> Marques
                    </a>
                    <a href="{{ path('brick_collections') }}" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-layer-group"></i> Collections
                    </a>
                </div>
            </div>
        </div>
    </div>

    {% if pagination.getTotalItemCount > 0 %}
    <div class="row">
        {% for set in pagination %}
        <div class="col-6 col-md-4 col-lg-3 col-xl-2 mb-4">
            <div class="card h-100 brick-card shadow-sm">
                <div class="brick-cover-wrapper text-center p-2" style="background: linear-gradient(135deg, #fff8e1 0%, #ffe0b2 100%);">
                    <a href="{{ path('brick_detail', {id: set.id}) }}">
                        <img class="img-fluid" alt="{{ set.nom }}" src="{{ set.mainImageUrl }}"
                             style="max-height: 180px; object-fit: contain;"
                             onerror="this.src='/images/brick-default.svg';" />
                    </a>
                </div>
                <div class="card-body p-2">
                    <h6 class="card-title mb-1">
                        <a href="{{ path('brick_detail', {id: set.id}) }}" class="text-dark text-decoration-none brick-titre">
                            {{ set.nom|length > 35 ? set.nom|slice(0, 35) ~ '...' : set.nom }}
                        </a>
                    </h6>
                    <span class="badge badge-warning mb-1">{{ set.reference }}</span>
                    {% if set.marque %}
                    <span class="badge badge-secondary mb-1">{{ set.marque.nom }}</span>
                    {% endif %}
                    {% if set.collection %}
                    <p class="card-text small text-muted mb-1">
                        <i class="fas fa-layer-group"></i> {{ set.collection.nom }}
                    </p>
                    {% endif %}
                    <p class="card-text small text-muted mb-1">
                        {% if set.annee %}<i class="fas fa-calendar"></i> {{ set.annee }}{% endif %}
                        {% if set.nbPieces %} · <i class="fas fa-puzzle-piece"></i> {{ set.nbPieces }}{% endif %}
                    </p>
                </div>
                <div class="card-footer bg-white border-top-0 p-2 pt-0">
                    <div class="d-flex justify-content-between align-items-center">
                        {% if set.prix %}
                        <span class="badge badge-success">{{ set.prix|number_format(2) }} €</span>
                        {% else %}
                        <span></span>
                        {% endif %}
                        <a href="{{ path('brick_detail', {id: set.id}) }}" class="btn btn-sm btn-outline-warning">
                            <i class="fas fa-eye"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    <div class="d-flex justify-content-center mt-4">
        {{ knp_pagination_render(pagination) }}
    </div>
    {% else %}
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> Aucun set trouvé.
        {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
        <a href="{{ path('brick_new') }}" class="alert-link">Ajouter un set</a>
        {% endif %}
    </div>
    {% endif %}
</div>

<style>
    .brick-card { transition: transform 0.2s, box-shadow 0.2s; border: 1px solid #ffe0b2; }
    .brick-card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(255, 107, 53, 0.2) !important; }
    .brick-titre:hover { color: #ff6b35 !important; }
    .brick-cover-wrapper { border-radius: 0.25rem 0.25rem 0 0; min-height: 180px; }
</style>
{% endblock %}

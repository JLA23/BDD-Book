{% extends 'base.html.twig' %}

{% block title %}BDD-Book - {{ livre.titre }}{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <!-- Bouton retour + modifier -->
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
        {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
            {% set isOwner = false %}
            {% for lienUser in livre.listeUser %}
                {% if lienUser.user.id == app.user.id %}
                    {% set isOwner = true %}
                {% endif %}
            {% endfor %}
            {% if isOwner %}
                <a href="{{ path('livre_modifier', {id: livre.id}) }}" class="btn btn-primary btn-sm">
                    <i class="fas fa-edit"></i> Modifier
                </a>
            {% endif %}
        {% endif %}
    </div>

    <!-- Card principale -->
    <div class="card shadow-sm">
        <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <h4 class="mb-0 text-white">
                <i class="fas fa-book"></i> {{ livre.titre }}
                {% if livre.tome and livre.tome > 0 %}
                    <span class="badge badge-light ml-2">Tome {{ livre.tome }}</span>
                {% endif %}
            </h4>
        </div>
        
        <div class="card-body">
            <div class="row">
                <!-- Colonne Image -->
                <div class="col-md-4 text-center mb-4">
                    <div class="livre-cover-container position-relative">
                        <img id='img-{{ livre.id }}' 
                             class="img-fluid rounded shadow clickable-image" 
                             alt="{{ livre.titre }}" 
                             src="{{ livre.getBestImage ?: asset('images/book-no-cover.svg') }}"
                             style="max-height: 400px; object-fit: contain; cursor: pointer;"
                             onerror="this.onerror=null; this.src='{{ asset('images/book-no-cover.svg') }}';" />
                        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                        <button type="button" class="btn btn-light btn-sm edit-cover-btn" data-toggle="modal" data-target="#editCoverModal" title="Modifier la couverture">
                            <i class="fas fa-edit"></i>
                        </button>
                        {% endif %}
                    </div>
                    {% if livre.getImage2 and is_granted('IS_AUTHENTICATED_FULLY') %}
                    <span class="badge badge-info mt-2"><i class="fas fa-link"></i> Image externe</span>
                    {% endif %}
                </div>
                
                <!-- Colonne Informations -->
                <div class="col-md-8">
                    <!-- Auteurs -->
                    {% if livre.listeAuteur|length > 0 %}
                    <div class="mb-3">
                        <h6 class="text-muted mb-2"><i class="fas fa-pen-fancy"></i> Auteur(s)</h6>
                        <div>
                            {% for auteur in livre.listeAuteur %}
                                <a href="{{ path('auteur_detail', {'id': auteur.auteur.id}) }}" class="badge badge-primary mr-1 mb-1" style="font-size: 0.9rem;">
                                    {{ auteur.auteur.nom }}
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                    
                    <!-- Infos principales -->
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="info-item mb-3">
                                <small class="text-muted d-block"><i class="fas fa-building"></i> Éditeur</small>
                                <strong>{% if livre.edition %}{{ livre.edition.nom }}{% else %}-{% endif %}</strong>
                            </div>
                        </div>
                        {% if livre.collection %}
                        <div class="col-sm-6">
                            <div class="info-item mb-3">
                                <small class="text-muted d-block"><i class="fas fa-layer-group"></i> Collection</small>
                                <strong>{{ livre.collection.nom }}</strong>
                            </div>
                        </div>
                        {% endif %}
                        <div class="col-sm-6">
                            <div class="info-item mb-3">
                                <small class="text-muted d-block"><i class="fas fa-calendar"></i> Année</small>
                                <strong>{% if livre.annee %}{{ livre.annee }}{% else %}-{% endif %}</strong>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="info-item mb-3">
                                <small class="text-muted d-block"><i class="fas fa-barcode"></i> ISBN</small>
                                <strong>{% if livre.isbn %}{{ livre.isbn }}{% else %}-{% endif %}</strong>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="info-item mb-3">
                                <small class="text-muted d-block"><i class="fas fa-euro-sign"></i> Prix</small>
                                <strong>{{ livre.prixBase|number_format(2) }} {% if livre.monnaie %}{{ livre.monnaie.symbole }}{% endif %}</strong>
                            </div>
                        </div>
                        {% if livre.category %}
                        <div class="col-sm-6">
                            <div class="info-item mb-3">
                                <small class="text-muted d-block"><i class="fas fa-tag"></i> Catégorie</small>
                                <strong>{{ livre.category.nom }}</strong>
                            </div>
                        </div>
                        {% endif %}
                        {% if livre.pages and livre.pages > 0 %}
                        <div class="col-sm-6">
                            <div class="info-item mb-3">
                                <small class="text-muted d-block"><i class="fas fa-file-alt"></i> Pages</small>
                                <strong>{{ livre.pages }}</strong>
                            </div>
                        </div>
                        {% endif %}
                        {% if livre.amazon %}
                        <div class="col-sm-6">
                            <div class="info-item mb-3">
                                <small class="text-muted d-block"><i class="fas fa-external-link-alt"></i> Lien</small>
                                <a href="{{ livre.amazon }}" target="_blank" class="btn btn-sm btn-outline-warning">
                                    <i class="fas fa-shopping-cart"></i> Voir le produit
                                </a>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                    
                    <!-- Synopsis -->
                    {% if livre.resume %}
                    <div class="mt-3">
                        <h6 class="text-muted mb-2"><i class="fas fa-align-left"></i> Synopsis</h6>
                        <div class="bg-light p-3 rounded" style="max-height: 200px; overflow-y: auto;">
                            {{ livre.resume|nl2br }}
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    
    <!-- Propriétaires -->
    <div class="card mt-4 mb-5 shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center" style="cursor: pointer;" data-toggle="collapse" data-target="#proprietairesCollapse" aria-expanded="false" aria-controls="proprietairesCollapse">
            <h5 class="mb-0">
                <i class="fas fa-users"></i> Propriétaires ({{ livre.listeUser|length }})
                <i class="fas fa-chevron-down float-right ml-2"></i>
            </h5>
            {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                <a href="{{ path('livre_ajouter_utilisateur', {id: livre.id}) }}" class="btn btn-sm btn-success" onclick="event.stopPropagation();">
                    <i class="fas fa-user-plus mr-1"></i> Ajouter
                </a>
            {% endif %}
        </div>
        <div id="proprietairesCollapse" class="collapse">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th><i class="fas fa-user"></i> Utilisateur</th>
                            <th><i class="fas fa-calendar-alt"></i> Date d'acquisition</th>
                            <th><i class="fas fa-comment"></i> Commentaire</th>
                            {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                                <th class="text-right"><i class="fas fa-cogs"></i> Actions</th>
                            {% endif %}
                        </tr>
                    </thead>
                    <tbody>
                        {% for lienuserLivre in livre.listeUser %}
                        <tr>
                            <td>
                                <strong>{{ lienuserLivre.user.name }} {{ lienuserLivre.user.lastName }}</strong>
                            </td>
                            <td>
                                {% if lienuserLivre.dateAchat %}
                                    {{ lienuserLivre.dateAchat|date('d/m/Y') }}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if lienuserLivre.commentaire %}
                                    {{ lienuserLivre.commentaire }}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                                <td class="text-right text-nowrap">
                                    <a href="{{ path('livre_transferer', {id: livre.id, lienId: lienuserLivre.id}) }}" 
                                       class="btn btn-sm btn-outline-info" title="Transférer">
                                        <i class="fas fa-exchange-alt"></i>
                                    </a>
                                    <form method="post" action="{{ path('livre_supprimer_utilisateur', {id: livre.id, lienId: lienuserLivre.id}) }}" class="d-inline" onsubmit="return confirm('Retirer {{ lienuserLivre.user.fullName }} des propriétaires de ce livre ?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Retirer">
                                            <i class="fas fa-user-minus"></i>
                                        </button>
                                    </form>
                                </td>
                            {% endif %}
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        </div>
    </div>
</div>

<!-- The Image Modal -->
<div id="myModal" class="image-modal">
    <span class="image-modal-close">&times;</span>
    <img class="image-modal-content" id="img01">
    <div id="caption"></div>
</div>

<!-- Modale d'édition de couverture -->
{% if is_granted('IS_AUTHENTICATED_FULLY') %}
<div class="modal fade" id="editCoverModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <h5 class="modal-title text-white">
                    <i class="fas fa-image"></i> Modifier la couverture
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <!-- Image actuelle -->
                <div class="text-center mb-4">
                    <img src="{{ livre.getBestImage ?: asset('images/book-no-cover.svg') }}" 
                         class="img-thumbnail" 
                         style="max-height: 200px;" 
                         alt="Couverture actuelle"
                         onerror="this.onerror=null; this.src='{{ asset('images/book-no-cover.svg') }}';">
                    {% if livre.getImage2 %}
                    <div class="mt-2">
                        <span class="badge badge-info"><i class="fas fa-link"></i> Image externe</span>
                        <br>
                        <small class="text-muted text-break">{{ livre.getImage2 }}</small>
                    </div>
                    {% endif %}
                </div>
                
                <hr>
                
                <!-- Options d'édition -->
                <div class="row">
                    {% if livre.isbn %}
                    <!-- Scraper des images -->
                    <div class="col-md-6 mb-3">
                        <div class="card h-100 border-primary">
                            <div class="card-body text-center">
                                <i class="fas fa-magic fa-2x text-primary mb-2"></i>
                                <h6>Recherche automatique</h6>
                                <p class="small text-muted">Rechercher des images sur Amazon, Bedetheque, Decitre</p>
                                <button type="button" id="scrapeCoverBtn" class="btn btn-primary btn-sm" data-livre-id="{{ livre.id }}">
                                    <i class="fas fa-search"></i> Scraper des images
                                </button>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                    
                    <!-- Upload manuel -->
                    <div class="col-md-6 mb-3">
                        <div class="card h-100 border-success">
                            <div class="card-body text-center">
                                <i class="fas fa-upload fa-2x text-success mb-2"></i>
                                <h6>Uploader une image</h6>
                                <p class="small text-muted">Depuis votre ordinateur</p>
                                <button type="button" id="openUploadModalBtn" class="btn btn-success btn-sm">
                                    <i class="fas fa-file-image"></i> Choisir un fichier
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <!-- URL manuelle -->
                    <div class="col-md-6 mb-3">
                        <div class="card h-100 border-secondary">
                            <div class="card-body text-center">
                                <i class="fas fa-link fa-2x text-secondary mb-2"></i>
                                <h6>URL manuelle</h6>
                                <p class="small text-muted">Coller l'URL d'une image</p>
                                <button type="button" id="openUrlModalBtn" class="btn btn-secondary btn-sm">
                                    <i class="fas fa-paste"></i> Saisir une URL
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    {% if livre.getImage2 %}
                    <!-- Revenir à l'image originale -->
                    <div class="col-md-6 mb-3">
                        <div class="card h-100 border-danger">
                            <div class="card-body text-center">
                                <i class="fas fa-undo fa-2x text-danger mb-2"></i>
                                <h6>Image originale</h6>
                                <p class="small text-muted">Supprimer l'image externe</p>
                                <button type="button" id="removeCoverUrlBtn" class="btn btn-outline-danger btn-sm">
                                    <i class="fas fa-trash"></i> Revenir à l'originale
                                </button>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modale Upload d'image -->
<div class="modal fade" id="uploadCoverModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
                <h5 class="modal-title text-white">
                    <i class="fas fa-upload"></i> Uploader une image
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body text-center">
                <p class="text-muted mb-3">Sélectionnez une image depuis votre ordinateur</p>
                
                <label for="uploadCoverInput" class="btn btn-success btn-lg mb-3" style="cursor: pointer;">
                    <i class="fas fa-file-image"></i> Choisir un fichier
                </label>
                <input type="file" id="uploadCoverInput" accept="image/*" style="display: none;" data-livre-id="{{ livre.id }}">
                
                <!-- Zone de prévisualisation -->
                <div id="uploadPreview" style="display: none;">
                    <hr>
                    <h6><i class="fas fa-eye"></i> Prévisualisation</h6>
                    <img id="uploadPreviewImg" class="img-thumbnail" style="max-height: 250px;" alt="Prévisualisation">
                    <div class="mt-3">
                        <button type="button" id="confirmUploadBtn" class="btn btn-success">
                            <i class="fas fa-check"></i> Confirmer
                        </button>
                        <button type="button" id="cancelUploadBtn" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Annuler
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modale URL manuelle -->
<div class="modal fade" id="manualUrlModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #6c757d 0%, #495057 100%);">
                <h5 class="modal-title text-white">
                    <i class="fas fa-link"></i> URL manuelle
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3">Collez l'URL d'une image de couverture</p>
                
                <div class="input-group mb-3">
                    <input type="url" id="manualUrlInput" class="form-control" placeholder="https://exemple.com/image.jpg">
                    <div class="input-group-append">
                        <button type="button" id="previewManualUrlBtn" class="btn btn-primary">
                            <i class="fas fa-eye"></i> Prévisualiser
                        </button>
                    </div>
                </div>
                
                <!-- Zone de prévisualisation -->
                <div id="manualPreview" class="text-center"></div>
            </div>
        </div>
    </div>
</div>
{% endif %}

<!-- Modale de sélection d'images scrapées -->
<div class="modal fade" id="scrapedImagesModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <h5 class="modal-title text-white">
                    <i class="fas fa-images"></i> Images trouvées
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="scrapedImagesLoading" class="text-center py-5">
                    <i class="fas fa-spinner fa-spin fa-3x text-primary"></i>
                    <p class="mt-3">Recherche en cours sur Amazon, Bedetheque, Decitre...</p>
                    <small class="text-muted">Cela peut prendre jusqu'à 2 minutes</small>
                </div>
                <div id="scrapedImagesContent" style="display: none;">
                    <p class="text-muted mb-3">
                        <i class="fas fa-info-circle"></i> Cliquez sur une image pour la sélectionner
                    </p>
                    <div id="scrapedImagesGrid" class="row"></div>
                </div>
                <div id="scrapedImagesError" class="alert alert-warning" style="display: none;">
                    <i class="fas fa-exclamation-triangle"></i> <span id="scrapedImagesErrorMsg"></span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .info-item {
        padding: 10px;
        background: #f8f9fa;
        border-radius: 8px;
        border-left: 3px solid #667eea;
    }
    .livre-cover-container {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        padding: 20px;
        border-radius: 10px;
    }
    .edit-cover-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        opacity: 0.7;
        transition: all 0.3s;
        border-radius: 50%;
        width: 36px;
        height: 36px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }
    .edit-cover-btn:hover {
        opacity: 1;
        transform: scale(1.1);
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }
    .scraped-image-card {
        cursor: pointer;
        transition: all 0.3s;
        border: 3px solid transparent;
    }
    .scraped-image-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.2);
    }
    .scraped-image-card.selected {
        border-color: #667eea;
        box-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
    }
    .scraped-image-card img {
        max-height: 300px;
        object-fit: contain;
        width: 100%;
    }
</style>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/image-modal.js') }}"></script>
    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
    <script>
    $(document).ready(function() {
        var livreId = {{ livre.id }};
        var selectedFile = null;
        var foundImageUrl = null;
        
        // Ouvrir la modale Upload depuis la modale principale
        $('#openUploadModalBtn').on('click', function() {
            $('#editCoverModal').modal('hide');
            $('#uploadCoverModal').modal('show');
        });
        
        // Ouvrir la modale URL depuis la modale principale
        $('#openUrlModalBtn').on('click', function() {
            $('#editCoverModal').modal('hide');
            $('#manualUrlModal').modal('show');
        });
        
        // Gestion de l'upload de fichier
        $('#uploadCoverInput').on('change', function(e) {
            var file = e.target.files[0];
            if (!file) return;
            
            // Vérifier que c'est une image
            if (!file.type.match('image.*')) {
                alert('Veuillez sélectionner un fichier image');
                return;
            }
            
            selectedFile = file;
            
            // Prévisualiser l'image
            var reader = new FileReader();
            reader.onload = function(e) {
                $('#uploadPreviewImg').attr('src', e.target.result);
                $('#uploadPreview').show();
            };
            reader.readAsDataURL(file);
        });
        
        // Confirmer l'upload
        $('#confirmUploadBtn').on('click', function() {
            if (!selectedFile) return;
            
            var btn = $(this);
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Upload...');
            
            var formData = new FormData();
            formData.append('cover', selectedFile);
            
            $.ajax({
                url: '/books/' + livreId + '/upload-cover',
                method: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        alert('Erreur: ' + (response.message || 'Erreur inconnue'));
                        btn.prop('disabled', false).html('<i class="fas fa-check"></i> Confirmer');
                    }
                },
                error: function(xhr) {
                    var errorMsg = 'Erreur lors de l\'upload';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMsg = xhr.responseJSON.message;
                    }
                    alert(errorMsg);
                    btn.prop('disabled', false).html('<i class="fas fa-check"></i> Confirmer');
                }
            });
        });
        
        // Annuler l'upload
        $('#cancelUploadBtn').on('click', function() {
            $('#uploadPreview').hide();
            $('#uploadCoverInput').val('');
            selectedFile = null;
        });
        
        // Supprimer l'image externe et revenir à l'originale
        $('#removeCoverUrlBtn').on('click', function() {
            if (!confirm('Revenir à l\'image originale stockée en base ?')) return;
            
            var btn = $(this);
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Suppression...');
            
            $.ajax({
                url: '/books/' + livreId + '/supprimer-url-couverture',
                method: 'POST',
                success: function(response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        btn.prop('disabled', false).html('<i class="fas fa-undo"></i> Revenir à l\'image originale');
                        alert(response.message);
                    }
                },
                error: function() {
                    btn.prop('disabled', false).html('<i class="fas fa-undo"></i> Revenir à l\'image originale');
                    alert('Erreur lors de la suppression');
                }
            });
        });
        
        // Prévisualisation URL manuelle
        $('#previewManualUrlBtn').on('click', function() {
            var url = $('#manualUrlInput').val().trim();
            if (!url) {
                alert('Veuillez saisir une URL');
                return;
            }
            
            foundImageUrl = url;
            $('#manualPreview').html(
                '<img src="' + url + '" class="img-thumbnail" style="max-height: 200px;" alt="Prévisualisation" onerror="this.parentElement.innerHTML=\'<span class=text-danger>Image non accessible</span>\'">' +
                '<br><button type="button" id="applyManualUrlBtn" class="btn btn-success btn-sm mt-2"><i class="fas fa-check"></i> Utiliser cette image</button>'
            );
        });
        
        $(document).on('click', '#applyManualUrlBtn', function() {
            if (!foundImageUrl) return;
            
            var btn = $(this);
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Enregistrement...');
            
            $.ajax({
                url: '/books/' + livreId + '/update-cover-url',
                method: 'POST',
                data: { imageUrl: foundImageUrl },
                success: function(response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        btn.prop('disabled', false).html('<i class="fas fa-check"></i> Utiliser cette image');
                        alert(response.message);
                    }
                },
                error: function() {
                    btn.prop('disabled', false).html('<i class="fas fa-check"></i> Utiliser cette image');
                    alert('Erreur lors de l\'enregistrement');
                }
            });
        });
        
        // Scraper des images via Puppeteer
        $('#scrapeCoverBtn').on('click', function() {
            var livreId = $(this).data('livre-id');
            
            // Fermer la modale d'édition et ouvrir la modale des images
            $('#editCoverModal').modal('hide');
            $('#scrapedImagesModal').modal('show');
            
            // Réinitialiser l'état
            $('#scrapedImagesLoading').show();
            $('#scrapedImagesContent').hide();
            $('#scrapedImagesError').hide();
            $('#scrapedImagesGrid').empty();
            
            // Appeler le contrôleur qui va appeler Puppeteer
            $.ajax({
                url: '/books/' + livreId + '/scrape-covers',
                method: 'GET',
                dataType: 'json',
                timeout: 120000, // 2 minutes
                success: function(response) {
                    $('#scrapedImagesLoading').hide();
                    
                    if (response.images && response.images.length > 0) {
                        $('#scrapedImagesContent').show();
                        
                        // Afficher les images
                        response.images.forEach(function(image) {
                            var card = $('<div class="col-md-4 mb-3">' +
                                '<div class="card scraped-image-card h-100" data-image-url="' + image.url + '">' +
                                    '<div class="card-body text-center p-2">' +
                                        '<img src="' + image.url + '" alt="Couverture" class="img-fluid mb-2" style="max-height: 300px; object-fit: contain;">' +
                                        '<div class="mb-2">' +
                                            '<span class="badge badge-primary">' + image.source + '</span>' +
                                            '<span class="badge badge-secondary ml-1">' + image.quality + '</span>' +
                                        '</div>' +
                                        '<button class="btn btn-success btn-sm btn-block select-image-btn">Utiliser</button>' +
                                    '</div>' +
                                '</div>' +
                            '</div>');
                            
                            $('#scrapedImagesGrid').append(card);
                        });
                        
                        // Gérer la sélection d'image
                        $('.select-image-btn').on('click', function() {
                            var imageUrl = $(this).closest('.scraped-image-card').data('image-url');
                            
                            if (!confirm('Utiliser cette image comme couverture ?')) {
                                return;
                            }
                            
                            // Marquer comme sélectionnée
                            $('.scraped-image-card').removeClass('selected');
                            $(this).closest('.scraped-image-card').addClass('selected');
                            $(this).html('<i class="fas fa-spinner fa-spin"></i>').prop('disabled', true);
                            
                            // Enregistrer l'URL
                            $.ajax({
                                url: '/books/' + livreId + '/update-cover-url',
                                method: 'POST',
                                data: { imageUrl: imageUrl },
                                dataType: 'json',
                                success: function(response) {
                                    if (response.success) {
                                        $('#scrapedImagesModal').modal('hide');
                                        location.reload();
                                    } else {
                                        alert('Erreur: ' + (response.error || 'Erreur inconnue'));
                                        $('.select-image-btn').html('Utiliser').prop('disabled', false);
                                    }
                                },
                                error: function(xhr) {
                                    var errorMsg = 'Erreur lors de l\'enregistrement de l\'image';
                                    if (xhr.responseJSON && xhr.responseJSON.error) {
                                        errorMsg = xhr.responseJSON.error;
                                    }
                                    alert(errorMsg);
                                    $('.select-image-btn').html('Utiliser').prop('disabled', false);
                                }
                            });
                        });
                        
                    } else {
                        $('#scrapedImagesError').show();
                        $('#scrapedImagesErrorMsg').text('Aucune image trouvée sur BDGuest, Fnac, Decitre et Amazon pour l\'ISBN ' + response.isbn);
                    }
                },
                error: function(xhr) {
                    $('#scrapedImagesLoading').hide();
                    $('#scrapedImagesError').show();
                    var errorMsg = 'Erreur lors de la recherche d\'images. Le service Puppeteer est-il démarré ?';
                    if (xhr.responseJSON && xhr.responseJSON.error) {
                        errorMsg = xhr.responseJSON.error;
                    }
                    $('#scrapedImagesErrorMsg').text(errorMsg);
                }
            });
        });
    });
    </script>
    {% endif %}
{% endblock %}
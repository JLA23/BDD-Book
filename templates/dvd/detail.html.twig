{% extends 'base.html.twig' %}

{% block title %}{{ dvd.titre }} - BDD-DVD{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <a href="{{ path('dvd_list') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
                {% if is_granted('IS_AUTHENTICATED_REMEMBERED') and app.user.canRegisterInSection('dvd') %}
                <div>
                    <a href="{{ path('dvd_edit', {id: dvd.id}) }}" class="btn btn-outline-primary">
                        <i class="fas fa-edit"></i> Modifier
                    </a>
                    <form method="post" action="{{ path('dvd_delete', {id: dvd.id}) }}" class="d-inline" onsubmit="return confirm('Confirmer la suppression ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ dvd.id) }}">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="fas fa-trash"></i> Supprimer
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>

            <div class="card shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, #1a5276 0%, #3498db 100%);">
                    <h4 class="mb-0 text-white">{{ dvd.titre }}</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center">
                            <img src="{{ dvd.mainImage ?: '/images/dvd-default.svg' }}" class="img-fluid rounded shadow mb-3" style="max-height: 350px;">
                            <div>
                                <span class="badge badge-info mr-1">
                                    {{ dvd.format == 'bluray' ? 'Blu-ray' : dvd.format == 'bluray4k' ? 'Blu-ray 4K' : 'DVD' }}
                                </span>
                                <span class="badge badge-secondary">
                                    {{ dvd.type == 'serie' ? 'Série' : 'Film' }}
                                </span>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <p><strong><i class="fas fa-calendar"></i> Année :</strong> {{ dvd.annee ?: '-' }}</p>
                                    <p><strong><i class="fas fa-building"></i> Éditeur :</strong> {{ dvd.editeur ?: '-' }}</p>
                                    {% if dvd.edition %}
                                    <p><strong><i class="fas fa-layer-group"></i> Édition :</strong> {{ dvd.edition }}</p>
                                    {% endif %}
                                    {% if dvd.ean %}
                                    <p><strong><i class="fas fa-barcode"></i> EAN :</strong> {{ dvd.ean }}</p>
                                    {% endif %}
                                </div>
                            </div>
                            {% if dvd.description %}
                            <div class="mb-3">
                                <h6>Description</h6>
                                <p>{{ dvd.description|nl2br }}</p>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            {% embed 'components/proprietaires_card.html.twig' with { count: owners|length } %}


                {% block header_actions %}
                    {% if is_granted('IS_AUTHENTICATED_REMEMBERED') and app.user.canRegisterInSection('dvd') %}
                        <a href="{{ path('dvd_add_owner', {id: dvd.id}) }}" class="btn btn-sm btn-success" onclick="event.stopPropagation();">
                            <i class="fas fa-user-plus mr-1"></i>
                            {% if userLinks|length > 0 %}Ajouter un autre exemplaire{% else %}J'ai ce DVD / Blu-ray{% endif %}
                        </a>
                    {% endif %}


                {% endblock %}


                {% block content %}
{% if owners|length == 0 %}
                            <div class="p-3 text-center text-muted">
                                <i class="fas fa-info-circle"></i> Personne ne possède ce DVD / Blu-ray.
                            </div>
                        {% else %}
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="thead-light">
                                        <tr>
                                            <th><i class="fas fa-user"></i> Utilisateur</th>
                                            <th><i class="fas fa-calendar"></i> Date d'achat</th>
                                            <th><i class="fas fa-euro-sign"></i> Prix</th>
                                            <th><i class="fas fa-comment"></i> Commentaire</th>
                                            {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                                                <th class="text-right"><i class="fas fa-cogs"></i> Actions</th>
                                            {% endif %}
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for owner in owners %}
                                        <tr>
                                            <td><strong>{{ owner.user.name }} {{ owner.user.lastname }}</strong></td>
                                            <td>{{ owner.dateAchat ? owner.dateAchat|date('d/m/Y') : '-' }}</td>
                                            <td>{% include 'components/owner_prix_cell.html.twig' with { prix: owner.prixAchat } %}</td>
                                            <td>{{ owner.commentaire ? owner.commentaire|u.truncate(50, '...') : '-' }}</td>
                                            {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                                                <td class="text-right text-nowrap">
                                                    {% if owner.user == app.user %}
                                                        <a href="{{ path('dvd_edit_owner', {id: dvd.id, lienId: owner.id}) }}" class="btn btn-sm btn-outline-primary" title="Modifier">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                        <form action="{{ path('dvd_remove_owner', {id: dvd.id, lienId: owner.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Retirer ce DVD / Blu-ray de votre collection ?');">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ owner.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Retirer">
                                                                <i class="fas fa-user-minus"></i>
                                                            </button>
                                                        </form>
                                                    {% endif %}
                                                </td>
                                            {% endif %}
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    


                {% endblock %}


            {% endembed %}
        </div>
    </div>
</div>
{% endblock %}

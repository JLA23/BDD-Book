{% extends 'base.html.twig' %}

{% block title %}BDD-DVD - Base de données de DVD & Blu-ray{% endblock %}

{% block body %}
    <div id="acceuilSite">
        <div class="text-center mb-4">
            <h1 class="display-5 font-weight-bold" style="color: #1a5276;">
                <i class="fas fa-compact-disc"></i> BDD-DVD
            </h1>
            <p class="lead text-muted">Base de données de DVD & Blu-ray de la famille Lefebvre</p>
        </div>

        <div class="card mb-4">
            <div class="card-header" style="background: linear-gradient(135deg, #1a5276 0%, #3498db 100%);">
                <h5 class="mb-0 text-white"><i class="fas fa-search"></i><span class="d-none d-md-inline"> Rechercher</span> un DVD / Blu-ray</h5>
            </div>
            <div class="card-body">
                <form action="{{ path('dvd_list') }}" method="get">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group mb-3">
                                <label for="search" class="font-weight-bold text-dark">Que recherchez-vous ?</label>
                                {% include 'components/search_input_group.html.twig' with {
                                    icon: 'fas fa-compact-disc',
                                    accent: '#1a5276',
                                    name: 'search',
                                    input_id: 'searchInput',
                                    placeholder: 'Titre, éditeur ou code-barres EAN...',
                                    scanner: true,
                                    scanner_hint: true,
                                    scanner_hint_text: 'Scannez le code-barres du boîtier pour rechercher dans votre catalogue.'
                                } %}
                                <small class="form-text text-muted d-none d-md-block">Recherche par titre, éditeur ou code-barres EAN.</small>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label class="font-weight-bold text-dark">Format</label>
                                <select name="format" class="form-control form-control-lg">
                                    <option value="">Tous</option>
                                    <option value="dvd">DVD</option>
                                    <option value="bluray">Blu-ray</option>
                                    <option value="bluray4k">Blu-ray 4K</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label class="font-weight-bold text-dark">Par Collection</label>
                                <select name="user" class="form-control form-control-lg">
                                    <option value="">Tous</option>
                                    {% for user in users %}
                                        <option value="{{ user.id }}">{{ user.name }} {{ user.lastname }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-lg text-white px-5" style="background: linear-gradient(135deg, #1a5276 0%, #3498db 100%);">
                            <i class="fas fa-search"></i><span class="d-none d-md-inline"> Rechercher</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <a href="{{ path('dvd_list') }}" class="card h-100 text-decoration-none" style="cursor: pointer;">
                    <div class="card-body text-center py-4">
                        <div class="mb-3">
                            <i class="fas fa-compact-disc fa-3x" style="color: #1a5276;"></i>
                        </div>
                        <h5 class="card-title text-dark">Tous les DVD / Blu-ray</h5>
                        <p class="card-text text-muted small">Parcourir le catalogue ({{ totalDvds }})</p>
                    </div>
                </a>
            </div>
            <div class="col-md-4 mb-3">
                <a href="{{ path('dvd_users') }}" class="card h-100 text-decoration-none" style="cursor: pointer;">
                    <div class="card-body text-center py-4">
                        <div class="mb-3">
                            <i class="fas fa-users fa-3x text-success"></i>
                        </div>
                        <h5 class="card-title text-dark">Collections</h5>
                        <p class="card-text text-muted small">Par utilisateur</p>
                    </div>
                </a>
            </div>
            {% if is_granted('IS_AUTHENTICATED_REMEMBERED') and app.user.canRegisterInSection('dvd') %}
            <div class="col-md-4 mb-3">
                <a href="{{ path('dvd_ajouter') }}" class="card h-100 text-decoration-none" style="cursor: pointer;">
                    <div class="card-body text-center py-4">
                        <div class="mb-3">
                            <i class="fas fa-plus-circle fa-3x" style="color: #1a5276;"></i>
                        </div>
                        <h5 class="card-title text-dark">Ajouter un DVD / Blu-ray</h5>
                        <p class="card-text text-muted small">Ajouter à la base</p>
                    </div>
                </a>
            </div>
            {% endif %}
        </div>
    </div>

{% include 'components/barcode_scanner.html.twig' with { accent_from: '#1a5276', accent_to: '#3498db' } %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% include 'components/barcode_scanner_init.html.twig' with { accent_from: '#1a5276', accent_to: '#3498db' } %}
{% endblock %}

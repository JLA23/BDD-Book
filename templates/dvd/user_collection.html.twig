{% extends 'base.html.twig' %}

{% block title %}Collection de {{ user.name }} - BDD-DVD{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #1a5276;">
            <i class="fas fa-compact-disc"></i> Collection de {{ user.name }} {{ user.lastname }}
        </h2>
        <a href="{{ path('dvd_users') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </div>

    <div class="row">
        {% for lien in liens %}
        {% set dvd = lien.dvd %}
        <div class="col-md-3 col-sm-6 mb-4">
            <a href="{{ path('dvd_detail', {id: dvd.id}) }}" class="text-decoration-none">
                <div class="card h-100 shadow-sm">
                    <div class="position-relative">
                        {% if lien.displayImage %}
                            <img src="{{ lien.displayImage }}" class="card-img-top" style="height: 250px; object-fit: contain; background: #f8f9fa;">
                        {% else %}
                            <img src="{{ dvd.mainImage ?: '/images/dvd-default.svg' }}" class="card-img-top" style="height: 250px; object-fit: contain; background: #f8f9fa;">
                        {% endif %}
                        <span class="badge badge-info position-absolute" style="top: 5px; right: 5px;">
                            {{ dvd.format == 'bluray' ? 'Blu-ray' : dvd.format == 'bluray4k' ? '4K' : 'DVD' }}
                        </span>
                    </div>
                    <div class="card-body p-2">
                        <h6 class="card-title text-dark text-truncate mb-1">{{ dvd.titre }}</h6>
                        <p class="text-muted small mb-0">
                            {% if dvd.annee %}{{ dvd.annee }} · {% endif %}
                            {{ dvd.type == 'serie' ? 'Serie' : 'Film' }}
                        </p>
                        {% if lien.prixAchat %}
                            <p class="text-success small mb-0">{{ lien.prixAchat }} €</p>
                        {% endif %}
                        {% if lien.dateAchat %}
                            <p class="text-muted small mb-0">{{ lien.dateAchat|date('d/m/Y') }}</p>
                        {% endif %}
                    </div>
                </div>
            </a>
        </div>
        {% else %}
        <div class="col-12 text-center py-5">
            <p class="text-muted">Aucun DVD / Blu-ray dans cette collection.</p>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

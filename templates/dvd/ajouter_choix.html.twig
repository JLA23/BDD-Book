{% extends 'base.html.twig' %}

{% block title %}Ajouter un DVD / Blu-ray{% endblock %}

{% block body %}
<div class="container mt-4">

    <h1 class="mb-4"><i class="fas fa-plus-circle mr-2" style="color: #1a5276;"></i>Ajouter un DVD / Blu-ray</h1>

    <div class="row justify-content-center">
        <div class="col-md-5 mb-4">
            <div class="card h-100 shadow-sm" style="border-color: #1a5276;">
                <div class="card-body text-center d-flex flex-column">
                    <div class="mb-3">
                        <i class="fas fa-search fa-3x" style="color: #1a5276;"></i>
                    </div>
                    <h5 class="card-title">Rechercher via API</h5>
                    <p class="card-text text-muted flex-grow-1">
                        Rechercher un DVD ou Blu-ray par son <strong>titre</strong> via l'API DVDFR.
                        Les informations seront récupérées automatiquement.
                    </p>
                    {% if apiConfigured %}
                        <div class="mb-3">
                            <span class="badge badge-light border">
                                <i class="fas fa-compact-disc mr-1"></i>DVDFR
                            </span>
                        </div>
                    {% else %}
                        <div class="mb-3">
                            <span class="badge badge-warning">
                                <i class="fas fa-exclamation-triangle mr-1"></i>API non configurée
                            </span>
                        </div>
                    {% endif %}
                    <a href="{{ path('dvd_search_api') }}" class="btn btn-block mt-auto text-white" style="background: linear-gradient(135deg, #1a5276 0%, #3498db 100%);">
                        <i class="fas fa-search mr-1"></i> Rechercher via API
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-5 mb-4">
            <div class="card h-100 shadow-sm border-warning">
                <div class="card-body text-center d-flex flex-column">
                    <div class="mb-3">
                        <i class="fas fa-edit fa-3x text-warning"></i>
                    </div>
                    <h5 class="card-title">Saisie manuelle</h5>
                    <p class="card-text text-muted flex-grow-1">
                        Remplir manuellement toutes les informations du DVD / Blu-ray.
                    </p>
                    <a href="{{ path('dvd_new') }}" class="btn btn-warning btn-block mt-auto">
                        <i class="fas fa-edit mr-1"></i> Saisie manuelle
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

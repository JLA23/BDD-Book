{# Carte repliable « Propriétaires » (Bootstrap 4) — utiliser avec {% embed %} #}
{% set collapse_id = collapse_id|default('proprietairesCollapse') %}
<div class="card mt-4 mb-5 shadow-sm{{ card_class is defined and card_class ? ' ' ~ card_class : '' }}">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center collapsed" style="cursor: pointer;" data-toggle="collapse" data-target="#{{ collapse_id }}" aria-expanded="false" aria-controls="{{ collapse_id }}">
        <h5 class="mb-0">
            <i class="fas fa-users"></i> {{ title|default('Propriétaires') }}{% if count is defined %} ({{ count }}){% endif %}
            <i class="fas fa-chevron-down float-right ml-2 proprietaires-chevron"></i>
        </h5>
        {% block header_actions %}{% endblock %}
    </div>
    <div id="{{ collapse_id }}" class="collapse">
        <div class="card-body{{ body_class is defined and body_class ? ' ' ~ body_class : ' p-0' }}">
            {% block content %}{% endblock %}
        </div>
    </div>
</div>

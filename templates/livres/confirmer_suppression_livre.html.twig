{% extends 'base.html.twig' %}

{% block title %}Confirmer la suppression - {{ livre.titre }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('index') }}">Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('livreDetail', {id: livre.id}) }}">{{ livre.titre }}</a></li>
            <li class="breadcrumb-item active">Confirmer la suppression</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fas fa-exclamation-triangle mr-2"></i>Attention : dernier propriétaire</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <img src="{{ livre.getBestImage }}" class="img-fluid rounded mb-3" alt="{{ livre.titre }}" style="max-height: 200px; object-fit: contain;">
                        <h4>{{ livre.titre }}</h4>
                        {% if livre.isbn %}<p class="text-muted"><i class="fas fa-barcode mr-1"></i>{{ livre.isbn }}</p>{% endif %}
                    </div>

                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-circle mr-2"></i>
                        <strong>{{ lien.user.fullName }}</strong> est le dernier propriétaire de ce livre.
                        Si vous le retirez, le livre sera <strong>définitivement supprimé</strong> de la base de données.
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="{{ path('livreDetail', {id: livre.id}) }}" class="btn btn-secondary">
                            <i class="fas fa-arrow-left mr-1"></i> Annuler
                        </a>
                        <form method="post" action="{{ path('livre_supprimer_utilisateur', {id: livre.id, lienId: lien.id}) }}">
                            <input type="hidden" name="delete_livre" value="1">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Êtes-vous sûr de vouloir supprimer définitivement ce livre ?')">
                                <i class="fas fa-trash mr-1"></i> Retirer l'utilisateur et supprimer le livre
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

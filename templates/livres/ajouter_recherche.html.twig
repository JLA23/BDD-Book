{% extends 'base.html.twig' %}

{% block title %}BDD-Book - Rechercher un livre par ISBN{% endblock %}

{% block body %}
<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('books_index') }}">BDD-Books</a></li>
            <li class="breadcrumb-item"><a href="{{ path('livre_ajouter') }}">Ajouter un livre</a></li>
            <li class="breadcrumb-item active">Rechercher par ISBN</li>
        </ol>
    </nav>

    <h1 class="mb-4"><i class="fas fa-barcode text-primary mr-2"></i>Rechercher un livre par ISBN</h1>

    <!-- Formulaire de recherche -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="post" action="{{ path('livre_ajouter_recherche') }}" id="searchForm">
                <div class="row align-items-end">
                    <div class="col-md-10">
                        <div class="form-group mb-md-0">
                            <label>ISBN</label>
                            <div class="input-group">
                                <input type="text" name="query" id="isbnInput" class="form-control" 
                                       value="{{ query }}" 
                                       placeholder="Entrez un ISBN (ex: 978-2-07-036822-8)..."
                                       autofocus>
                                <div class="input-group-append d-md-none">
                                    <button type="button" class="btn btn-outline-secondary" id="scanBarcodeBtn" title="Scanner un code-barres">
                                        <i class="fas fa-barcode"></i>
                                    </button>
                                </div>
                            </div>
                            <small class="form-text text-muted d-md-none">
                                <i class="fas fa-camera text-primary"></i> Cliquez sur l'icône code-barres pour scanner.
                            </small>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary btn-block">
                            <i class="fas fa-search mr-1"></i> Chercher
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Overlay de chargement -->
    <div id="loadingOverlay" class="d-none">
        <div class="card shadow-sm mb-4">
            <div class="card-body text-center py-5">
                <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
                    <span class="sr-only">Chargement...</span>
                </div>
                <h5 class="mb-3" id="loadingTitle">Recherche en cours...</h5>
                <p class="text-muted mb-2" id="loadingMessage">Vérification en base de données...</p>
                <div class="progress mb-3" style="height: 6px; max-width: 400px; margin: 0 auto;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" id="loadingBar" style="width: 0%"></div>
                </div>
                <small class="text-muted" id="loadingDetail">
                    <i class="fas fa-clock mr-1"></i>Cela peut prendre jusqu'à 2 minutes si le livre n'est pas en base...
                </small>
            </div>
        </div>
    </div>

    <!-- Livres existants en base -->
    {% if existingBooks is defined and existingBooks is not empty %}
        <div class="alert alert-info">
            <i class="fas fa-database mr-2"></i>
            Ce livre existe déjà dans la base de données. Vous pouvez l'associer à votre compte ou créer une nouvelle fiche.
        </div>

        <div class="row">
            {% for livre in existingBooks %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm border-info">
                        <div class="row no-gutters">
                            <div class="col-4">
                                {% if livre.getBestImage %}
                                    <img src="{{ livre.getBestImage }}" 
                                         class="card-img p-2" 
                                         alt="{{ livre.titre }}"
                                         style="object-fit: contain; max-height: 200px;">
                                {% else %}
                                    <div class="d-flex align-items-center justify-content-center h-100 bg-light">
                                        <i class="fas fa-book fa-3x text-muted"></i>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="col-8">
                                <div class="card-body p-3">
                                    <h6 class="card-title mb-1">{{ livre.titre }}</h6>
                                    {% if livre.listeAuteur|length > 0 %}
                                        <p class="card-text text-muted small mb-1">
                                            <i class="fas fa-user mr-1"></i>
                                            {% for la in livre.listeAuteur %}{{ la.auteur.nom }}{% if not loop.last %}, {% endif %}{% endfor %}
                                        </p>
                                    {% endif %}
                                    {% if livre.edition %}
                                        <p class="card-text text-muted small mb-1">
                                            <i class="fas fa-building mr-1"></i>{{ livre.edition.nom }}
                                        </p>
                                    {% endif %}
                                    {% if livre.annee %}
                                        <p class="card-text text-muted small mb-1">
                                            <i class="fas fa-calendar mr-1"></i>{{ livre.annee }}
                                        </p>
                                    {% endif %}
                                    <p class="card-text text-muted small mb-1">
                                        <i class="fas fa-barcode mr-1"></i>{{ livre.isbn }}
                                    </p>
                                    <span class="badge badge-info">
                                        <i class="fas fa-users mr-1"></i>{{ livre.listeUser|length }} propriétaire{{ livre.listeUser|length > 1 ? 's' : '' }}
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white p-2">
                            <div class="d-flex">
                                <a href="{{ path('livre_ajouter_associer', {id: livre.id}) }}" class="btn btn-sm btn-success flex-grow-1 mr-1">
                                    <i class="fas fa-link mr-1"></i> Associer à mon compte
                                </a>
                                <a href="{{ path('livreDetail', {id: livre.id}) }}" class="btn btn-sm btn-outline-info">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="text-center mb-4">
            <a href="{{ path('livre_ajouter_formulaire', {isbn: query}) }}" class="btn btn-outline-warning">
                <i class="fas fa-plus mr-1"></i> Créer une nouvelle fiche malgré tout
            </a>
        </div>
    {% elseif noResults is defined and noResults %}
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle mr-2"></i>
            Aucun résultat trouvé pour l'ISBN "<strong>{{ query }}</strong>". 
            <a href="{{ path('livre_ajouter_formulaire', {isbn: query}) }}">Saisissez le livre manuellement</a>.
        </div>
    {% endif %}
</div>

<!-- Overlay plein écran pour le scanner - HORS de tout conteneur -->
<div id="barcodeScannerOverlay">
    <div class="scanner-header">
        <span><i class="fas fa-barcode"></i> Scanner ISBN</span>
        <button type="button" class="btn btn-light btn-sm" id="closeScannerBtn">
            <i class="fas fa-times"></i> Fermer
        </button>
    </div>
    <div id="barcodeReader"></div>
    <div class="scanner-footer">
        <div class="d-flex align-items-center justify-content-center mb-2">
            <label class="mr-2 mb-0"><i class="fas fa-camera"></i> Caméra :</label>
            <select id="cameraSelect" class="form-control form-control-sm" style="width: auto; max-width: 200px;">
                <option value="">Chargement...</option>
            </select>
        </div>
        <p class="mb-0 small"><i class="fas fa-info-circle"></i> Positionnez le code-barres dans le cadre</p>
    </div>
</div>

<style>
    /* Arrondir le bord droit de l'input sur desktop (quand le bouton scan est caché) */
    @media (min-width: 768px) {
        #isbnInput {
            border-top-right-radius: 0.25rem !important;
            border-bottom-right-radius: 0.25rem !important;
        }
    }
    
    #barcodeScannerOverlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: #000;
        z-index: 999999;
        flex-direction: column;
    }
    #barcodeScannerOverlay.active {
        display: flex !important;
    }
    #barcodeScannerOverlay .scanner-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: bold;
    }
    #barcodeScannerOverlay #barcodeReader {
        flex: 1;
        width: 100%;
        background: #000;
    }
    #barcodeScannerOverlay .scanner-footer {
        background: rgba(0,0,0,0.9);
        color: white;
        padding: 12px 15px;
        text-align: center;
    }
    html.scanner-open,
    html.scanner-open body {
        overflow: hidden !important;
        height: 100% !important;
    }
</style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <!-- Bibliothèque html5-qrcode pour le scan de code-barres -->
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    
    <script>
    $(document).ready(function() {
        let html5QrCode = null;
        let isScanning = false;
        
        // Vérifier si le contexte est sécurisé (HTTPS ou localhost)
        function isSecureContext() {
            return window.isSecureContext || 
                   location.protocol === 'https:' || 
                   location.hostname === 'localhost' || 
                   location.hostname === '127.0.0.1';
        }
        
        // Vérifier si la caméra est disponible
        function checkCameraAvailable() {
            return navigator.mediaDevices && navigator.mediaDevices.getUserMedia;
        }
        
        // Ouvrir le scanner en plein écran
        $('#scanBarcodeBtn').click(function() {
            // Afficher l'overlay plein écran
            $('#barcodeScannerOverlay').addClass('active');
            
            // Empêcher le scroll
            $('html').addClass('scanner-open');
            
            // Vérifier le contexte sécurisé
            if (!isSecureContext()) {
                showScannerError(
                    "<strong>Connexion non sécurisée</strong><br>" +
                    "Le scanner nécessite HTTPS."
                );
                return;
            }
            
            // Vérifier si l'API caméra est disponible
            if (!checkCameraAvailable()) {
                showScannerError(
                    "<strong>Caméra non disponible</strong><br>" +
                    "Votre navigateur ne supporte pas la caméra."
                );
                return;
            }
            
            // Demander la permission
            requestCameraPermission();
        });
        
        // Fermer le scanner
        $('#closeScannerBtn').click(function() {
            closeScanner();
        });
        
        function closeScanner() {
            stopScanner();
            $('#barcodeScannerOverlay').removeClass('active');
            $('html').removeClass('scanner-open');
            $('#barcodeReader').html('');
        }
        
        function requestCameraPermission() {
            // Afficher un message de chargement
            $('#barcodeReader').html(
                '<div class="d-flex align-items-center justify-content-center h-100" style="color: white;">' +
                '<div class="text-center">' +
                '<i class="fas fa-spinner fa-spin fa-3x mb-3"></i>' +
                '<p>Accès à la caméra...</p>' +
                '</div></div>'
            );
            
            // Demander la permission avec haute résolution pour les petits codes-barres
            navigator.mediaDevices.getUserMedia({ 
                video: { 
                    facingMode: "environment",
                    width: { ideal: 3840, min: 1920 },
                    height: { ideal: 2160, min: 1080 },
                    focusMode: "continuous"
                } 
            })
            .then(function(stream) {
                stream.getTracks().forEach(track => track.stop());
                $('#barcodeReader').html('');
                startScanner();
            })
            .catch(function(err) {
                console.error("Erreur permission caméra:", err);
                
                let errorMessage = "";
                if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
                    errorMessage = "<strong>Permission refusée</strong><br>Autorisez l'accès à la caméra.";
                } else if (err.name === 'NotFoundError') {
                    errorMessage = "<strong>Aucune caméra</strong><br>Pas de caméra détectée.";
                } else {
                    errorMessage = "<strong>Erreur</strong><br>" + (err.message || "Erreur inconnue");
                }
                
                showScannerError(errorMessage);
            });
        }
        
        let availableCameras = [];
        let currentCameraId = null;
        
        const scannerConfig = {
            fps: 15,
            qrbox: function(viewfinderWidth, viewfinderHeight) {
                let width = Math.floor(viewfinderWidth * 0.9);
                let height = Math.floor(viewfinderHeight * 0.5);
                return { width: width, height: height };
            },
            experimentalFeatures: {
                useBarCodeDetectorIfSupported: true
            },
            formatsToSupport: [
                Html5QrcodeSupportedFormats.EAN_13,
                Html5QrcodeSupportedFormats.EAN_8,
                Html5QrcodeSupportedFormats.UPC_A,
                Html5QrcodeSupportedFormats.UPC_E,
                Html5QrcodeSupportedFormats.CODE_128,
                Html5QrcodeSupportedFormats.CODE_39
            ]
        };
        
        async function loadCameras() {
            try {
                const allCameras = await Html5Qrcode.getCameras();
                console.log("Toutes les caméras:", allCameras);
                
                // Filtrer pour ne garder que les caméras arrière (back)
                availableCameras = allCameras.filter(cam => {
                    const label = cam.label.toLowerCase();
                    return label.includes('back') || label.includes('arrière') || label.includes('environment');
                });
                
                // Si aucune caméra arrière trouvée, utiliser toutes les caméras
                if (availableCameras.length === 0) {
                    availableCameras = allCameras;
                }
                
                console.log("Caméras arrière:", availableCameras);
                
                const select = $('#cameraSelect');
                select.empty();
                
                if (availableCameras && availableCameras.length > 0) {
                    availableCameras.forEach((cam, index) => {
                        // Simplifier le label pour l'affichage
                        let label = cam.label || `Caméra ${index + 1}`;
                        // Nettoyer le label
                        label = label.replace(/camera2?\s*/gi, '').replace(/facing\s*/gi, '');
                        if (label.length > 25) {
                            label = label.substring(0, 25) + '...';
                        }
                        select.append(`<option value="${cam.id}">Objectif ${index + 1}: ${label}</option>`);
                    });
                    // Sélectionner le 2ème objectif par défaut s'il existe (souvent meilleur pour les codes-barres)
                    return availableCameras.length > 1 ? availableCameras[1].id : availableCameras[0].id;
                } else {
                    select.append('<option value="">Aucune caméra</option>');
                    return null;
                }
            } catch(err) {
                console.error("Erreur liste caméras:", err);
                return null;
            }
        }
        
        async function startScanner() {
            if (isScanning) return;
            
            html5QrCode = new Html5Qrcode("barcodeReader");
            
            try {
                // Charger la liste des caméras
                const defaultCameraId = await loadCameras();
                
                if (defaultCameraId) {
                    currentCameraId = defaultCameraId;
                    $('#cameraSelect').val(currentCameraId);
                    await startWithCamera(currentCameraId);
                } else {
                    // Essayer avec facingMode
                    await html5QrCode.start(
                        { facingMode: "environment" },
                        scannerConfig,
                        onScanSuccess,
                        onScanError
                    );
                    isScanning = true;
                }
            } catch(err) {
                console.error("Erreur démarrage scanner:", err);
                showScannerError("<strong>Erreur</strong><br>Impossible de démarrer le scanner.");
            }
        }
        
        async function startWithCamera(cameraId) {
            try {
                await html5QrCode.start(
                    cameraId,
                    scannerConfig,
                    onScanSuccess,
                    onScanError
                );
                isScanning = true;
                currentCameraId = cameraId;
            } catch(err) {
                console.error("Erreur démarrage caméra:", err);
                throw err;
            }
        }
        
        // Changement de caméra
        $('#cameraSelect').on('change', async function() {
            const newCameraId = $(this).val();
            if (newCameraId && newCameraId !== currentCameraId && isScanning) {
                try {
                    // Arrêter le scanner actuel
                    await html5QrCode.stop();
                    isScanning = false;
                    // Démarrer avec la nouvelle caméra
                    await startWithCamera(newCameraId);
                } catch(err) {
                    console.error("Erreur changement caméra:", err);
                }
            }
        });
        
        function stopScanner() {
            if (html5QrCode && isScanning) {
                html5QrCode.stop().then(() => {
                    isScanning = false;
                    html5QrCode.clear();
                }).catch((err) => {
                    console.error("Erreur arrêt scanner:", err);
                    isScanning = false;
                });
            }
        }
        
        function onScanSuccess(decodedText, decodedResult) {
            // Vibration sur mobile
            if (navigator.vibrate) {
                navigator.vibrate(100);
            }
            
            // Mettre le code dans le champ ISBN
            $('#isbnInput').val(decodedText);
            
            // Afficher succès et fermer
            $('.scanner-footer p').html('<i class="fas fa-check-circle text-success"></i> Code détecté : <strong>' + decodedText + '</strong>');
            
            setTimeout(function() {
                closeScanner();
            }, 800);
        }
        
        function onScanError(errorMessage) {
            // Ignorer les erreurs normales
        }
        
        function showScannerError(message) {
            $('#barcodeReader').html(
                '<div class="d-flex align-items-center justify-content-center h-100">' +
                '<div class="alert alert-danger m-4 text-center">' +
                '<i class="fas fa-exclamation-triangle fa-2x mb-2"></i><br>' + message +
                '<br><button class="btn btn-outline-danger btn-sm mt-3" onclick="$(\'#closeScannerBtn\').click();">Fermer</button>' +
                '</div></div>'
            );
        }
    });
    </script>
    
    <script>
        (function() {
            const form = document.getElementById('searchForm');
            if (!form) return;

            const steps = [
                { msg: 'Vérification en base de données...', pct: 5 },
                { msg: 'Lancement du scraping Amazon...', pct: 15 },
                { msg: 'Lancement du scraping Decitre...', pct: 30 },
                { msg: 'Recherche sur Bedetheque...', pct: 60 },
                { msg: 'Fusion des résultats...', pct: 90 },
            ];

            form.addEventListener('submit', function() {
                const query = document.getElementById('isbnInput').value.trim();
                if (!query) return;

                const overlay = document.getElementById('loadingOverlay');
                overlay.classList.remove('d-none');

                const bar = document.getElementById('loadingBar');
                const msgEl = document.getElementById('loadingMessage');
                const submitBtn = form.querySelector('button[type="submit"]');

                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm mr-1"></span> Recherche...';

                let stepIndex = 0;
                const interval = setInterval(function() {
                    if (stepIndex < steps.length) {
                        msgEl.textContent = steps[stepIndex].msg;
                        bar.style.width = steps[stepIndex].pct + '%';
                        stepIndex++;
                    } else {
                        msgEl.textContent = 'Patientez, analyse des résultats...';
                        bar.style.width = '98%';
                    }
                }, 6000);
            });
        })();
    </script>
{% endblock %}

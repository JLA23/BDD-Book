{% extends 'base.html.twig' %}

{% block title %}BDD-Book - Livre déjà existant ?{% endblock %}

{% block body %}
<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('books_index') }}">BDD-Books</a></li>
            <li class="breadcrumb-item"><a href="{{ path('livre_ajouter') }}">Ajouter un livre</a></li>
            <li class="breadcrumb-item active">Doublon détecté</li>
        </ol>
    </nav>

    <div class="alert alert-warning">
        <h4 class="alert-heading"><i class="fas fa-exclamation-triangle mr-2"></i>Un livre similaire existe déjà !</h4>
        <p class="mb-0">
            Le livre <strong>"{{ nouveauLivre.titre }}"</strong>
            {% if nouveauLivre.isbn %}(ISBN : {{ nouveauLivre.isbn }}){% endif %}
            correspond à {{ doublons|length }} livre{{ doublons|length > 1 ? 's' : '' }} déjà enregistré{{ doublons|length > 1 ? 's' : '' }} en base.
        </p>
    </div>

    <h5 class="mb-3"><i class="fas fa-list mr-1"></i> Livre{{ doublons|length > 1 ? 's' : '' }} existant{{ doublons|length > 1 ? 's' : '' }}</h5>

    <div class="row mb-4">
        {% for livre in doublons %}
        <div class="col-md-6 col-lg-4 mb-3">
            <div class="card h-100 shadow-sm border-info">
                <div class="row no-gutters">
                    <div class="col-4">
                        {% if livre.bestImage %}
                            <img src="{{ livre.bestImage }}" class="card-img p-2" alt="{{ livre.titre }}" style="object-fit: contain; max-height: 180px;">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center h-100 bg-light">
                                <i class="fas fa-book fa-3x text-muted"></i>
                            </div>
                        {% endif %}
                    </div>
                    <div class="col-8">
                        <div class="card-body p-3">
                            <h6 class="card-title mb-1">{{ livre.titre }}</h6>
                            {% if livre.isbn %}
                                <p class="card-text text-muted small mb-1"><i class="fas fa-barcode mr-1"></i>{{ livre.isbn }}</p>
                            {% endif %}
                            {% if livre.edition %}
                                <p class="card-text text-muted small mb-1"><i class="fas fa-building mr-1"></i>{{ livre.edition.nom }}</p>
                            {% endif %}
                            {% if livre.annee %}
                                <p class="card-text text-muted small mb-1"><i class="fas fa-calendar mr-1"></i>{{ livre.annee }}</p>
                            {% endif %}
                            {% if livre.listeAuteur|length > 0 %}
                                <p class="card-text text-muted small mb-1">
                                    <i class="fas fa-user mr-1"></i>
                                    {% for lien in livre.listeAuteur %}
                                        {{ lien.auteur.nom }}{% if not loop.last %}, {% endif %}
                                    {% endfor %}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white p-2">
                    <a href="{{ path('livre_ajouter_associer', {id: livre.id}) }}" class="btn btn-info btn-sm btn-block">
                        <i class="fas fa-link mr-1"></i> C'est ce livre, l'ajouter à ma bibliothèque
                    </a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <hr>

    <h5 class="mb-3"><i class="fas fa-plus-circle mr-1"></i> Ou bien...</h5>

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card shadow-sm border-success">
                <div class="card-body text-center py-4">
                    <i class="fas fa-file-alt fa-3x text-success mb-3"></i>
                    <h5>Créer une nouvelle fiche</h5>
                    <p class="text-muted">Ce n'est pas le même livre. Créer une fiche séparée avec les informations saisies.</p>
                    <form method="post" action="{{ path('livre_ajouter_confirmer_nouveau') }}">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-plus mr-1"></i> Créer une nouvelle fiche
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card shadow-sm border-secondary">
                <div class="card-body text-center py-4">
                    <i class="fas fa-arrow-left fa-3x text-secondary mb-3"></i>
                    <h5>Revenir au formulaire</h5>
                    <p class="text-muted">Modifier les informations et réessayer.</p>
                    <a href="{{ path('livre_ajouter_formulaire') }}" class="btn btn-secondary">
                        <i class="fas fa-arrow-left mr-1"></i> Revenir
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
